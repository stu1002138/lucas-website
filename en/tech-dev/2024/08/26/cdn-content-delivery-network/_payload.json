[{"data":1,"prerenderedAt":883},["ShallowReactive",2],{"doc":3,"content-query-xNXQNc2rPT":499},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"keywords":11,"body":17,"_type":493,"_id":494,"_source":495,"_file":496,"_stem":497,"_extension":498},"/en/tech-dev/2024/08/26/cdn-content-delivery-network","26",false,"","Exploring the Functionality and Applications of Content Delivery Network (CDN)","Introducing the CDN architecture, functions and application scenarios, as well as implementation examples.","2024-08-26T00:00:00.000Z",[12,13,14,15,16],"Content Delivery Network","CDN advantages","Web acceleration","Server stability","Edge nodes",{"type":18,"children":19,"toc":487},"root",[20,28,42,46,51,56,61,64,76,81,96,106,109,114,119,124,129,152,157,160,171,176,181,186,191,196,201,224,227,235,238,248,253,258,261,272,283,294,299,304,309,312,323,334,345,356,361,369,380,391,402,407,412,415,426,431,436,441,446,451,456,467,472,477,482],{"type":21,"tag":22,"props":23,"children":24},"element","p",{},[25],{"type":26,"value":27},"text","This article discusses the differences between traditional website setups and those using CDN, as well as the structure of CDN and practical application demonstrations.",{"type":21,"tag":29,"props":30,"children":32},"h2",{"id":31},"traditional-website-setup",[33],{"type":21,"tag":34,"props":35,"children":39},"span",{"className":36},[37,38],"text-lg","font-bold",[40],{"type":26,"value":41},"Traditional Website Setup",{"type":21,"tag":43,"props":44,"children":45},"br",{},[],{"type":21,"tag":22,"props":47,"children":48},{},[49],{"type":26,"value":50},"In traditional website setups, website content is hosted on a single server.",{"type":21,"tag":22,"props":52,"children":53},{},[54],{"type":26,"value":55},"When a user clicks on a URL in their browser, it connects to DNS, which translates the URL into the website's IP address.",{"type":21,"tag":22,"props":57,"children":58},{},[59],{"type":26,"value":60},"The browser then connects directly to that server to retrieve website content.",{"type":21,"tag":43,"props":62,"children":63},{},[],{"type":21,"tag":22,"props":65,"children":66},{},[67,73],{"type":21,"tag":68,"props":69,"children":72},"img",{"alt":70,"src":71},"Traditional Website Process","https://cdn.lucas-chen.website/2024/08/26/01.png",[],{"type":21,"tag":43,"props":74,"children":75},{},[],{"type":21,"tag":22,"props":77,"children":78},{},[79],{"type":26,"value":80},"This method has the following disadvantages:",{"type":21,"tag":82,"props":83,"children":84},"ul",{},[85,91],{"type":21,"tag":86,"props":87,"children":88},"li",{},[89],{"type":26,"value":90},"The farther away a user is from the server, the slower the speed (especially for global websites).",{"type":21,"tag":86,"props":92,"children":93},{},[94],{"type":26,"value":95},"Server stability is reduced (high traffic and multiple simultaneous connections to the same server increase the chance of a server crash).",{"type":21,"tag":29,"props":97,"children":99},{"id":98},"introduction-to-cdn",[100],{"type":21,"tag":34,"props":101,"children":103},{"className":102},[37,38],[104],{"type":26,"value":105},"Introduction to CDN",{"type":21,"tag":43,"props":107,"children":108},{},[],{"type":21,"tag":22,"props":110,"children":111},{},[112],{"type":26,"value":113},"This led to the development of CDN.",{"type":21,"tag":22,"props":115,"children":116},{},[117],{"type":26,"value":118},"CDN stands for Content Delivery Network.",{"type":21,"tag":22,"props":120,"children":121},{},[122],{"type":26,"value":123},"It allows website content to be deployed to edge nodes at various locations.",{"type":21,"tag":22,"props":125,"children":126},{},[127],{"type":26,"value":128},"Users from different regions can access the nearest server to retrieve content, providing several advantages:",{"type":21,"tag":82,"props":130,"children":131},{},[132,137,142,147],{"type":21,"tag":86,"props":133,"children":134},{},[135],{"type":26,"value":136},"Faster load times (reducing physical distance).",{"type":21,"tag":86,"props":138,"children":139},{},[140],{"type":26,"value":141},"Reduced load on the main server (users access the nearest CDN server, decreasing the load on the origin server).",{"type":21,"tag":86,"props":143,"children":144},{},[145],{"type":26,"value":146},"Improved reliability (multiple CDN servers reduce the risk of downtime).",{"type":21,"tag":86,"props":148,"children":149},{},[150],{"type":26,"value":151},"Enhanced user experience (faster connection speeds, quicker website browsing, and reduced risk of site crashes).",{"type":21,"tag":22,"props":153,"children":154},{},[155],{"type":26,"value":156},"CDN Process Diagram:",{"type":21,"tag":43,"props":158,"children":159},{},[],{"type":21,"tag":22,"props":161,"children":162},{},[163,168],{"type":21,"tag":68,"props":164,"children":167},{"alt":165,"src":166},"CDN Process Diagram","https://cdn.lucas-chen.website/2024/08/26/02.png",[],{"type":21,"tag":43,"props":169,"children":170},{},[],{"type":21,"tag":22,"props":172,"children":173},{},[174],{"type":26,"value":175},"Website content is stored on the primary server.",{"type":21,"tag":22,"props":177,"children":178},{},[179],{"type":26,"value":180},"After configuring CDN, when users connect to the website, they first connect to DNS.",{"type":21,"tag":22,"props":182,"children":183},{},[184],{"type":26,"value":185},"DNS then redirects to CDN DNS.",{"type":21,"tag":22,"props":187,"children":188},{},[189],{"type":26,"value":190},"CDN DNS identifies the user’s location and returns the IP of the closest CDN edge server.",{"type":21,"tag":22,"props":192,"children":193},{},[194],{"type":26,"value":195},"The user connects to the nearest CDN edge server to retrieve website content.",{"type":21,"tag":22,"props":197,"children":198},{},[199],{"type":26,"value":200},"CDN is composed of the following:",{"type":21,"tag":82,"props":202,"children":203},{},[204,209,214,219],{"type":21,"tag":86,"props":205,"children":206},{},[207],{"type":26,"value":208},"Primary content server (Origin Server)",{"type":21,"tag":86,"props":210,"children":211},{},[212],{"type":26,"value":213},"DNS",{"type":21,"tag":86,"props":215,"children":216},{},[217],{"type":26,"value":218},"CDN DNS",{"type":21,"tag":86,"props":220,"children":221},{},[222],{"type":26,"value":223},"CDN edge servers (CDN servers distributed across different regions)",{"type":21,"tag":43,"props":225,"children":226},{},[],{"type":21,"tag":22,"props":228,"children":229},{},[230],{"type":21,"tag":68,"props":231,"children":234},{"alt":232,"src":233},"CDN composed","https://cdn.lucas-chen.website/2024/08/26/03.png",[],{"type":21,"tag":43,"props":236,"children":237},{},[],{"type":21,"tag":29,"props":239,"children":241},{"id":240},"practical-demonstration",[242],{"type":21,"tag":34,"props":243,"children":245},{"className":244},[37,38],[246],{"type":26,"value":247},"Practical Demonstration",{"type":21,"tag":22,"props":249,"children":250},{},[251],{"type":26,"value":252},"I uploaded several large GIF files to a test website and placed them far from Taiwan.",{"type":21,"tag":22,"props":254,"children":255},{},[256],{"type":26,"value":257},"Then I tested the load speed for the first time.",{"type":21,"tag":43,"props":259,"children":260},{},[],{"type":21,"tag":22,"props":262,"children":263},{},[264,269],{"type":21,"tag":68,"props":265,"children":268},{"alt":266,"src":267},"CDN Demo1","https://cdn.lucas-chen.website/2024/08/26/04.png",[],{"type":21,"tag":43,"props":270,"children":271},{},[],{"type":21,"tag":22,"props":273,"children":274},{},[275,280],{"type":21,"tag":68,"props":276,"children":279},{"alt":277,"src":278},"CDN Demo2","https://cdn.lucas-chen.website/2024/08/26/05.png",[],{"type":21,"tag":43,"props":281,"children":282},{},[],{"type":21,"tag":22,"props":284,"children":285},{},[286,291],{"type":21,"tag":68,"props":287,"children":290},{"alt":288,"src":289},"CDN Demo3","https://cdn.lucas-chen.website/2024/08/26/06.png",[],{"type":21,"tag":43,"props":292,"children":293},{},[],{"type":21,"tag":22,"props":295,"children":296},{},[297],{"type":26,"value":298},"It took almost 3 seconds to load the images.",{"type":21,"tag":22,"props":300,"children":301},{},[302],{"type":26,"value":303},"Then I set up CDN.",{"type":21,"tag":22,"props":305,"children":306},{},[307],{"type":26,"value":308},"I used Cloudflare as the CDN service provider since they offer a free plan.",{"type":21,"tag":43,"props":310,"children":311},{},[],{"type":21,"tag":22,"props":313,"children":314},{},[315,320],{"type":21,"tag":68,"props":316,"children":319},{"alt":317,"src":318},"CDN Demo4","https://cdn.lucas-chen.website/2024/08/26/07.png",[],{"type":21,"tag":43,"props":321,"children":322},{},[],{"type":21,"tag":22,"props":324,"children":325},{},[326,331],{"type":21,"tag":68,"props":327,"children":330},{"alt":328,"src":329},"CDN Demo5","https://cdn.lucas-chen.website/2024/08/26/08.png",[],{"type":21,"tag":43,"props":332,"children":333},{},[],{"type":21,"tag":22,"props":335,"children":336},{},[337,342],{"type":21,"tag":68,"props":338,"children":341},{"alt":339,"src":340},"CDN Demo6","https://cdn.lucas-chen.website/2024/08/26/09.png",[],{"type":21,"tag":43,"props":343,"children":344},{},[],{"type":21,"tag":22,"props":346,"children":347},{},[348,353],{"type":21,"tag":68,"props":349,"children":352},{"alt":350,"src":351},"CDN Demo7","https://cdn.lucas-chen.website/2024/08/26/10.png",[],{"type":21,"tag":43,"props":354,"children":355},{},[],{"type":21,"tag":22,"props":357,"children":358},{},[359],{"type":26,"value":360},"After configuring, there are two main CDN DNS settings required by your domain registrar.",{"type":21,"tag":22,"props":362,"children":363},{},[364,366],{"type":26,"value":365},"I purchased my domain on Gandi, so I need to configure the domain’s name servers there.\n",{"type":21,"tag":43,"props":367,"children":368},{},[],{"type":21,"tag":22,"props":370,"children":371},{},[372,377],{"type":21,"tag":68,"props":373,"children":376},{"alt":374,"src":375},"CDN Demo8","https://cdn.lucas-chen.website/2024/08/26/11.png",[],{"type":21,"tag":43,"props":378,"children":379},{},[],{"type":21,"tag":22,"props":381,"children":382},{},[383,388],{"type":21,"tag":68,"props":384,"children":387},{"alt":385,"src":386},"CDN Demo9","https://cdn.lucas-chen.website/2024/08/26/12.png",[],{"type":21,"tag":43,"props":389,"children":390},{},[],{"type":21,"tag":22,"props":392,"children":393},{},[394,399],{"type":21,"tag":68,"props":395,"children":398},{"alt":396,"src":397},"CDN Demo10","https://cdn.lucas-chen.website/2024/08/26/13.png",[],{"type":21,"tag":43,"props":400,"children":401},{},[],{"type":21,"tag":22,"props":403,"children":404},{},[405],{"type":26,"value":406},"Once configured, it looks like this.",{"type":21,"tag":22,"props":408,"children":409},{},[410],{"type":26,"value":411},"After enabling the CDN, you can observe the significant improvement in loading speed.",{"type":21,"tag":43,"props":413,"children":414},{},[],{"type":21,"tag":22,"props":416,"children":417},{},[418,423],{"type":21,"tag":68,"props":419,"children":422},{"alt":420,"src":421},"CDN Demo11","https://cdn.lucas-chen.website/2024/08/26/14.png",[],{"type":21,"tag":43,"props":424,"children":425},{},[],{"type":21,"tag":22,"props":427,"children":428},{},[429],{"type":26,"value":430},"Compared to not using CDN, where each image took almost 3 seconds to load, with CDN, each image now loads in less than 200 milliseconds.",{"type":21,"tag":22,"props":432,"children":433},{},[434],{"type":26,"value":435},"The speed has increased significantly.",{"type":21,"tag":22,"props":437,"children":438},{},[439],{"type":26,"value":440},"How do I check if the website is using CDN?",{"type":21,"tag":22,"props":442,"children":443},{},[444],{"type":26,"value":445},"You can add cdn-cgi/trace to the end of the URL.",{"type":21,"tag":22,"props":447,"children":448},{},[449],{"type":26,"value":450},"You’ll see something like colo=KHH, indicating that it’s connected to the Kaohsiung CDN edge server.",{"type":21,"tag":22,"props":452,"children":453},{},[454],{"type":26,"value":455},"For users in Taipei, connecting to Kaohsiung speeds up the connection significantly!",{"type":21,"tag":22,"props":457,"children":458},{},[459,464],{"type":21,"tag":68,"props":460,"children":463},{"alt":461,"src":462},"CDN Demo12","https://cdn.lucas-chen.website/2024/08/26/15.png",[],{"type":21,"tag":43,"props":465,"children":466},{},[],{"type":21,"tag":22,"props":468,"children":469},{},[470],{"type":26,"value":471},"CDN isn’t just for websites; it’s also used for video streaming, software downloads, and game image and video acceleration.",{"type":21,"tag":22,"props":473,"children":474},{},[475],{"type":26,"value":476},"CDN helps improve speed and enhances the user experience.",{"type":21,"tag":22,"props":478,"children":479},{},[480],{"type":26,"value":481},"If there are any parts I missed, feel free to add suggestions.",{"type":21,"tag":22,"props":483,"children":484},{},[485],{"type":26,"value":486},"Thank you all!",{"title":7,"searchDepth":488,"depth":488,"links":489},2,[490,491,492],{"id":31,"depth":488,"text":41},{"id":98,"depth":488,"text":105},{"id":240,"depth":488,"text":247},"markdown","content:en:tech-dev:2024:08:26:cdn-content-delivery-network.md","content","en/tech-dev/2024/08/26/cdn-content-delivery-network.md","en/tech-dev/2024/08/26/cdn-content-delivery-network","md",{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"keywords":500,"body":501,"_type":493,"_id":494,"_source":495,"_file":496,"_stem":497,"_extension":498},[12,13,14,15,16],{"type":18,"children":502,"toc":878},[503,507,515,518,522,526,530,533,542,546,557,565,568,572,576,580,584,603,607,610,619,623,627,631,635,639,643,662,665,671,674,682,686,690,693,702,711,720,724,728,732,735,744,753,762,771,775,782,791,800,809,813,817,820,829,833,837,841,845,849,853,862,866,870,874],{"type":21,"tag":22,"props":504,"children":505},{},[506],{"type":26,"value":27},{"type":21,"tag":29