[{"data":1,"prerenderedAt":460},["ShallowReactive",2],{"content-query-1RLI86IREL":3},[4],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"date":11,"keywords":12,"body":18,"_type":454,"_id":455,"_source":456,"_file":457,"_stem":458,"_extension":459},"/en/food/2023/06/11/chu-yu-omakase","11",false,"","Chu-yu - Japanese Omakase","Third Visit to Chuyu Sushi - A Japanese Omakase Restaurant in Taiwan.","2023-06-11T00:00:00.000Z",[13,14,15,16,17],"Food","Omakase","Japanese Cuisine","Chu-yu","Birthday Celebration",{"type":19,"children":20,"toc":451},"root",[21,29,34,39,43,55,71,76,81,86,101,106,111,114,125,130,135,138,149,154,159,164,169,172,183,194,205,216,227,238,249,260,271,282,293,304,315,326,337,348,353,358,363,368,371,382,387,390,400,405,410,415,428,433],{"type":22,"tag":23,"props":24,"children":25},"element","p",{},[26],{"type":27,"value":28},"text","This time, to celebrate my girlfriend's birthday,",{"type":22,"tag":23,"props":30,"children":31},{},[32],{"type":27,"value":33},"I specially booked this Japanese Omakase restaurant – Chuyu Sushi.",{"type":22,"tag":23,"props":35,"children":36},{},[37],{"type":27,"value":38},"This restaurant became a favorite of mine after a friend took me here for my birthday once, and I’ve remembered it ever since.",{"type":22,"tag":40,"props":41,"children":42},"br",{},[],{"type":22,"tag":23,"props":44,"children":45},{},[46,52],{"type":22,"tag":47,"props":48,"children":51},"img",{"alt":49,"src":50},"Restaurant Photo","https://scontent.ftpe14-1.fna.fbcdn.net/v/t39.30808-6/306085164_608610030967634_3901678845169237441_n.jpg?_nc_cat=106&ccb=1-7&_nc_sid=6ee11a&_nc_ohc=vwdLq4CScFEQ7kNvgGsEwgM&_nc_ht=scontent.ftpe14-1.fna&oh=00_AYDh52z3LSEPN5Fv3Q5DjR9nYw6-eC8ZS3Rq1f0NzW8yLA&oe=66D34150",[],{"type":22,"tag":40,"props":53,"children":54},{},[],{"type":22,"tag":23,"props":56,"children":57},{},[58,60],{"type":27,"value":59},"Image source: ",{"type":22,"tag":61,"props":62,"children":68},"a",{"className":63,"href":65,"rel":66},[64],"text-blue","https://www.facebook.com/chuyu.regent/",[67],"nofollow",[69],{"type":27,"value":70},"Chuyu Sushi - Regent Hotel",{"type":22,"tag":23,"props":72,"children":73},{},[74],{"type":27,"value":75},"Initially, the meal set at Chuyu Sushi was priced at TWD 1200 +10%.",{"type":22,"tag":23,"props":77,"children":78},{},[79],{"type":27,"value":80},"However, with inflation, the prices have increased as well.",{"type":22,"tag":23,"props":82,"children":83},{},[84],{"type":27,"value":85},"This restaurant is located in the B1 level of Regent Hotel Taipei, near Zhongshan MRT Station.",{"type":22,"tag":23,"props":87,"children":88},{},[89,91,99],{"type":27,"value":90},"Before dining, reservations must be made in advance through the ",{"type":22,"tag":61,"props":92,"children":96},{"className":93,"href":94,"rel":95},[64],"https://www.chu-yu.com.tw/",[67],[97],{"type":27,"value":98},"Chuyu Sushi official website",{"type":27,"value":100},".",{"type":22,"tag":23,"props":102,"children":103},{},[104],{"type":27,"value":105},"Full payment is required upfront, either via bank transfer or in-store credit card.",{"type":22,"tag":23,"props":107,"children":108},{},[109],{"type":27,"value":110},"Due to limited seating, I recommend booking early to secure your spot!",{"type":22,"tag":40,"props":112,"children":113},{},[],{"type":22,"tag":23,"props":115,"children":116},{},[117,122],{"type":22,"tag":47,"props":118,"children":121},{"alt":119,"src":120},"Seated","https://cdn.lucas-chen.website/2023/06/11/01.jpg",[],{"type":22,"tag":40,"props":123,"children":124},{},[],{"type":22,"tag":23,"props":126,"children":127},{},[128],{"type":27,"value":129},"Once seated, the staff will first serve a cup of hot tea, along with small appetizers and pickles.",{"type":22,"tag":23,"props":131,"children":132},{},[133],{"type":27,"value":134},"Then, the essence of Omakase slowly unfolds, with each dish meticulously crafted and served.",{"type":22,"tag":40,"props":136,"children":137},{},[],{"type":22,"tag":23,"props":139,"children":140},{},[141,146],{"type":22,"tag":47,"props":142,"children":145},{"alt":143,"src":144},"Appetizer","https://cdn.lucas-chen.website/2023/06/11/02.jpg",[],{"type":22,"tag":40,"props":147,"children":148},{},[],{"type":22,"tag":23,"props":150,"children":151},{},[152],{"type":27,"value":153},"The appetizer is refreshing and whets your appetite, preparing you for the culinary experience ahead.",{"type":22,"tag":23,"props":155,"children":156},{},[157],{"type":27,"value":158},"One by one, the dishes are served.",{"type":22,"tag":23,"props":160,"children":161},{},[162],{"type":27,"value":163},"Although I’ve forgotten most of the specific dish names due to the passage of time, I can confidently say that every dish was fresh and delicious, particularly the seafood used by the restaurant.",{"type":22,"tag":23,"props":165,"children":166},{},[167],{"type":27,"value":168},"Below are some of the dishes we enjoyed during the meal:",{"type":22,"tag":40,"props":170,"children":171},{},[],{"type":22,"tag":23,"props":173,"children":174},{},[175,180],{"type":22,"tag":47,"props":176,"children":179},{"alt":177,"src":178},"Second Dish","https://cdn.lucas-chen.website/2023/06/11/03.jpg",[],{"type":22,"tag":40,"props":181,"children":182},{},[],{"type":22,"tag":23,"props":184,"children":185},{},[186,191],{"type":22,"tag":47,"props":187,"children":190},{"alt":188,"src":189},"Third Dish","https://cdn.lucas-chen.website/2023/06/11/04.jpg",[],{"type":22,"tag":40,"props":192,"children":193},{},[],{"type":22,"tag":23,"props":195,"children":196},{},[197,202],{"type":22,"tag":47,"props":198,"children":201},{"alt":199,"src":200},"Fourth Dish","https://cdn.lucas-chen.website/2023/06/11/05.jpg",[],{"type":22,"tag":40,"props":203,"children":204},{},[],{"type":22,"tag":23,"props":206,"children":207},{},[208,213],{"type":22,"tag":47,"props":209,"children":212},{"alt":210,"src":211},"Fifth Dish","https://cdn.lucas-chen.website/2023/06/11/06.jpg",[],{"type":22,"tag":40,"props":214,"children":215},{},[],{"type":22,"tag":23,"props":217,"children":218},{},[219,224],{"type":22,"tag":47,"props":220,"children":223},{"alt":221,"src":222},"Sixth Dish","https://cdn.lucas-chen.website/2023/06/11/07.jpg",[],{"type":22,"tag":40,"props":225,"children":226},{},[],{"type":22,"tag":23,"props":228,"children":229},{},[230,235],{"type":22,"tag":47,"props":231,"children":234},{"alt":232,"src":233},"Seventh Dish","https://cdn.lucas-chen.website/2023/06/11/08.jpg",[],{"type":22,"tag":40,"props":236,"children":237},{},[],{"type":22,"tag":23,"props":239,"children":240},{},[241,246],{"type":22,"tag":47,"props":242,"children":245},{"alt":243,"src":244},"Eighth Dish","https://cdn.lucas-chen.website/2023/06/11/09.jpg",[],{"type":22,"tag":40,"props":247,"children":248},{},[],{"type":22,"tag":23,"props":250,"children":251},{},[252,257],{"type":22,"tag":47,"props":253,"children":256},{"alt":254,"src":255},"Ninth Dish","https://cdn.lucas-chen.website/2023/06/11/10.jpg",[],{"type":22,"tag":40,"props":258,"children":259},{},[],{"type":22,"tag":23,"props":261,"children":262},{},[263,268],{"type":22,"tag":47,"props":264,"children":267},{"alt":265,"src":266},"Tenth Dish","https://cdn.lucas-chen.website/2023/06/11/11.jpg",[],{"type":22,"tag":40,"props":269,"children":270},{},[],{"type":22,"tag":23,"props":272,"children":273},{},[274,279],{"type":22,"tag":47,"props":275,"children":278},{"alt":276,"src":277},"Eleventh Dish","https://cdn.lucas-chen.website/2023/06/11/12.jpg",[],{"type":22,"tag":40,"props":280,"children":281},{},[],{"type":22,"tag":23,"props":283,"children":284},{},[285,290],{"type":22,"tag":47,"props":286,"children":289},{"alt":287,"src":288},"Twelfth Dish","https://cdn.lucas-chen.website/2023/06/11/13.jpg",[],{"type":22,"tag":40,"props":291,"children":292},{},[],{"type":22,"tag":23,"props":294,"children":295},{},[296,301],{"type":22,"tag":47,"props":297,"children":300},{"alt":298,"src":299},"Thirteenth Dish","https://cdn.lucas-chen.website/2023/06/11/14.jpg",[],{"type":22,"tag":40,"props":302,"children":303},{},[],{"type":22,"tag":23,"props":305,"children":306},{},[307,312],{"type":22,"tag":47,"props":308,"children":311},{"alt":309,"src":310},"Fourteenth Dish","https://cdn.lucas-chen.website/2023/06/11/15.jpg",[],{"type":22,"tag":40,"props":313,"children":314},{},[],{"type":22,"tag":23,"props":316,"children":317},{},[318,323],{"type":22,"tag":47,"props":319,"children":322},{"alt":320,"src":321},"Fifteenth Dish","https://cdn.lucas-chen.website/2023/06/11/16.jpg",[],{"type":22,"tag":40,"props":324,"children":325},{},[],{"type":22,"tag":23,"props":327,"children":328},{},[329,334],{"type":22,"tag":47,"props":330,"children":333},{"alt":331,"src":332},"Sixteenth Dish","https://cdn.lucas-chen.website/2023/06/11/17.jpg",[],{"type":22,"tag":40,"props":335,"children":336},{},[],{"type":22,"tag":23,"props":338,"children":339},{},[340,345],{"type":22,"tag":47,"props":341,"children":344},{"alt":342,"src":343},"Seventeenth Dish","https://cdn.lucas-chen.website/2023/06/11/18.jpg",[],{"type":22,"tag":40,"props":346,"children":347},{},[],{"type":22,"tag":23,"props":349,"children":350},{},[351],{"type":27,"value":352},"The freshness of the ingredients is guaranteed, and each dish is incredibly flavorful.",{"type":22,"tag":23,"props":354,"children":355},{},[356],{"type":27,"value":357},"Midway through, the staff asked if we wanted to add extra lobster or wagyu beef, but since we estimated our portions just right, we declined additional orders.",{"type":22,"tag":23,"props":359,"children":360},{},[361],{"type":27,"value":362},"For the final main course, the restaurant prepares a seafood rice dish.",{"type":22,"tag":23,"props":364,"children":365},{},[366],{"type":27,"value":367},"If you’re still hungry, you can ask for more rice – the service is very considerate.",{"type":22,"tag":40,"props":369,"children":370},{},[],{"type":22,"tag":23,"props":372,"children":373},{},[374,379],{"type":22,"tag":47,"props":375,"children":378},{"alt":376,"src":377},"Eighteenth Dish","https://cdn.lucas-chen.website/2023/06/11/19.jpg",[],{"type":22,"tag":40,"props":380,"children":381},{},[],{"type":22,"tag":23,"props":383,"children":384},{},[385],{"type":27,"value":386},"At the end of the meal, dessert is served, paired with matcha, perfectly concluding the dining experience.",{"type":22,"tag":40,"props":388,"children":389},{},[],{"type":22,"tag":23,"props":391,"children":392},{},[393,397],{"type":22,"tag":47,"props":394,"children":396},{"alt":376,"src":395},"https://cdn.lucas-chen.website/2023/06/11/20.jpg",[],{"type":22,"tag":40,"props":398,"children":399},{},[],{"type":22,"tag":23,"props":401,"children":402},{},[403],{"type":27,"value":404},"The dessert is not overly sweet, and with the matcha, it tastes perfect.",{"type":22,"tag":23,"props":406,"children":407},{},[408],{"type":27,"value":409},"Overall, the food is exquisite, the ingredients are fresh, and the service is thoughtful. I highly recommend everyone to come and try it.",{"type":22,"tag":23,"props":411,"children":412},{},[413],{"type":27,"value":414},"Restaurant Name: Chuyu Sushi - Regent Hotel Taipei",{"type":22,"tag":23,"props":416,"children":417},{},[418,420],{"type":27,"value":419},"Address: ",{"type":22,"tag":61,"props":421,"children":425},{"className":422,"href":423,"rel":424},[64],"https://g.co/kgs/qMtEQUG",[67],[426],{"type":27,"value":427},"B2, No. 3, Lane 39, Section 2, Zhongshan North Road, Zhongshan District, Taipei City",{"type":22,"tag":23,"props":429,"children":430},{},[431],{"type":27,"value":432},"Reservation Hotline: (886)2-23660792 (10:00~21:00)",{"type":22,"tag":23,"props":434,"children":435},{},[436,438,445,448],{"type":27,"value":437},"Official Website: ",{"type":22,"tag":61,"props":439,"children":442},{"className":440,"href":94,"rel":441},[64],[67],[443],{"type":27,"value":444},"Link",{"type":22,"tag":40,"props":446,"children":447},{},[],{"type":22,"tag":40,"props":449,"children":450},{},[],{"title":8,"searchDepth":452,"depth":452,"links":453},2,[],"markdown","content:en:food:2023:06:11:chu-yu-omakase.md","content","en/food/2023/06/11/chu-yu-omakase.md","en/food/2023/06/11/chu-yu-omakase","md",1774336453197]