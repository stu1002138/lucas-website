[{"data":1,"prerenderedAt":797},["ShallowReactive",2],{"doc":3,"content-query-iqgeCqomgo":451},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"keywords":11,"body":17,"_type":445,"_id":446,"_source":447,"_file":448,"_stem":449,"_extension":450},"/en/food/2023/06/11/chu-yu-omakase","11",false,"","Chu-yu - Japanese Omakase","Third Visit to Chuyu Sushi - A Japanese Omakase Restaurant in Taiwan.","2023-06-11T00:00:00.000Z",[12,13,14,15,16],"Food","Omakase","Japanese Cuisine","Chu-yu","Birthday Celebration",{"type":18,"children":19,"toc":442},"root",[20,28,33,38,42,45,61,66,71,76,91,96,101,104,116,121,126,129,140,145,150,155,160,163,174,185,196,207,218,229,240,251,262,273,284,295,306,317,328,339,344,349,354,359,362,373,378,381,391,396,401,406,419,424],{"type":21,"tag":22,"props":23,"children":24},"element","p",{},[25],{"type":26,"value":27},"text","This time, to celebrate my girlfriend's birthday,",{"type":21,"tag":22,"props":29,"children":30},{},[31],{"type":26,"value":32},"I specially booked this Japanese Omakase restaurant – Chuyu Sushi.",{"type":21,"tag":22,"props":34,"children":35},{},[36],{"type":26,"value":37},"This restaurant became a favorite of mine after a friend took me here for my birthday once, and I’ve remembered it ever since.",{"type":21,"tag":39,"props":40,"children":41},"br",{},[],{"type":21,"tag":39,"props":43,"children":44},{},[],{"type":21,"tag":22,"props":46,"children":47},{},[48,50],{"type":26,"value":49},"Image source: ",{"type":21,"tag":51,"props":52,"children":58},"a",{"className":53,"href":55,"rel":56},[54],"text-blue","https://www.facebook.com/chuyu.regent/",[57],"nofollow",[59],{"type":26,"value":60},"Chuyu Sushi - Regent Hotel",{"type":21,"tag":22,"props":62,"children":63},{},[64],{"type":26,"value":65},"Initially, the meal set at Chuyu Sushi was priced at TWD 1200 +10%.",{"type":21,"tag":22,"props":67,"children":68},{},[69],{"type":26,"value":70},"However, with inflation, the prices have increased as well.",{"type":21,"tag":22,"props":72,"children":73},{},[74],{"type":26,"value":75},"This restaurant is located in the B1 level of Regent Hotel Taipei, near Zhongshan MRT Station.",{"type":21,"tag":22,"props":77,"children":78},{},[79,81,89],{"type":26,"value":80},"Before dining, reservations must be made in advance through the ",{"type":21,"tag":51,"props":82,"children":86},{"className":83,"href":84,"rel":85},[54],"https://www.chu-yu.com.tw/",[57],[87],{"type":26,"value":88},"Chuyu Sushi official website",{"type":26,"value":90},".",{"type":21,"tag":22,"props":92,"children":93},{},[94],{"type":26,"value":95},"Full payment is required upfront, either via bank transfer or in-store credit card.",{"type":21,"tag":22,"props":97,"children":98},{},[99],{"type":26,"value":100},"Due to limited seating, I recommend booking early to secure your spot!",{"type":21,"tag":39,"props":102,"children":103},{},[],{"type":21,"tag":22,"props":105,"children":106},{},[107,113],{"type":21,"tag":108,"props":109,"children":112},"img",{"alt":110,"src":111},"Seated","/img/posts/2023/06/11/01.jpg",[],{"type":21,"tag":39,"props":114,"children":115},{},[],{"type":21,"tag":22,"props":117,"children":118},{},[119],{"type":26,"value":120},"Once seated, the staff will first serve a cup of hot tea, along with small appetizers and pickles.",{"type":21,"tag":22,"props":122,"children":123},{},[124],{"type":26,"value":125},"Then, the essence of Omakase slowly unfolds, with each dish meticulously crafted and served.",{"type":21,"tag":39,"props":127,"children":128},{},[],{"type":21,"tag":22,"props":130,"children":131},{},[132,137],{"type":21,"tag":108,"props":133,"children":136},{"alt":134,"src":135},"Appetizer","/img/posts/2023/06/11/02.jpg",[],{"type":21,"tag":39,"props":138,"children":139},{},[],{"type":21,"tag":22,"props":141,"children":142},{},[143],{"type":26,"value":144},"The appetizer is refreshing and whets your appetite, preparing you for the culinary experience ahead.",{"type":21,"tag":22,"props":146,"children":147},{},[148],{"type":26,"value":149},"One by one, the dishes are served.",{"type":21,"tag":22,"props":151,"children":152},{},[153],{"type":26,"value":154},"Although I’ve forgotten most of the specific dish names due to the passage of time, I can confidently say that every dish was fresh and delicious, particularly the seafood used by the restaurant.",{"type":21,"tag":22,"props":156,"children":157},{},[158],{"type":26,"value":159},"Below are some of the dishes we enjoyed during the meal:",{"type":21,"tag":39,"props":161,"children":162},{},[],{"type":21,"tag":22,"props":164,"children":165},{},[166,171],{"type":21,"tag":108,"props":167,"children":170},{"alt":168,"src":169},"Second Dish","/img/posts/2023/06/11/03.jpg",[],{"type":21,"tag":39,"props":172,"children":173},{},[],{"type":21,"tag":22,"props":175,"children":176},{},[177,182],{"type":21,"tag":108,"props":178,"children":181},{"alt":179,"src":180},"Third Dish","/img/posts/2023/06/11/04.jpg",[],{"type":21,"tag":39,"props":183,"children":184},{},[],{"type":21,"tag":22,"props":186,"children":187},{},[188,193],{"type":21,"tag":108,"props":189,"children":192},{"alt":190,"src":191},"Fourth Dish","/img/posts/2023/06/11/05.jpg",[],{"type":21,"tag":39,"props":194,"children":195},{},[],{"type":21,"tag":22,"props":197,"children":198},{},[199,204],{"type":21,"tag":108,"props":200,"children":203},{"alt":201,"src":202},"Fifth Dish","/img/posts/2023/06/11/06.jpg",[],{"type":21,"tag":39,"props":205,"children":206},{},[],{"type":21,"tag":22,"props":208,"children":209},{},[210,215],{"type":21,"tag":108,"props":211,"children":214},{"alt":212,"src":213},"Sixth Dish","/img/posts/2023/06/11/07.jpg",[],{"type":21,"tag":39,"props":216,"children":217},{},[],{"type":21,"tag":22,"props":219,"children":220},{},[221,226],{"type":21,"tag":108,"props":222,"children":225},{"alt":223,"src":224},"Seventh Dish","/img/posts/2023/06/11/08.jpg",[],{"type":21,"tag":39,"props":227,"children":228},{},[],{"type":21,"tag":22,"props":230,"children":231},{},[232,237],{"type":21,"tag":108,"props":233,"children":236},{"alt":234,"src":235},"Eighth Dish","/img/posts/2023/06/11/09.jpg",[],{"type":21,"tag":39,"props":238,"children":239},{},[],{"type":21,"tag":22,"props":241,"children":242},{},[243,248],{"type":21,"tag":108,"props":244,"children":247},{"alt":245,"src":246},"Ninth Dish","/img/posts/2023/06/11/10.jpg",[],{"type":21,"tag":39,"props":249,"children":250},{},[],{"type":21,"tag":22,"props":252,"children":253},{},[254,259],{"type":21,"tag":108,"props":255,"children":258},{"alt":256,"src":257},"Tenth Dish","/img/posts/2023/06/11/11.jpg",[],{"type":21,"tag":39,"props":260,"children":261},{},[],{"type":21,"tag":22,"props":263,"children":264},{},[265,270],{"type":21,"tag":108,"props":266,"children":269},{"alt":267,"src":268},"Eleventh Dish","/img/posts/2023/06/11/12.jpg",[],{"type":21,"tag":39,"props":271,"children":272},{},[],{"type":21,"tag":22,"props":274,"children":275},{},[276,281],{"type":21,"tag":108,"props":277,"children":280},{"alt":278,"src":279},"Twelfth Dish","/img/posts/2023/06/11/13.jpg",[],{"type":21,"tag":39,"props":282,"children":283},{},[],{"type":21,"tag":22,"props":285,"children":286},{},[287,292],{"type":21,"tag":108,"props":288,"children":291},{"alt":289,"src":290},"Thirteenth Dish","/img/posts/2023/06/11/14.jpg",[],{"type":21,"tag":39,"props":293,"children":294},{},[],{"type":21,"tag":22,"props":296,"children":297},{},[298,303],{"type":21,"tag":108,"props":299,"children":302},{"alt":300,"src":301},"Fourteenth Dish","/img/posts/2023/06/11/15.jpg",[],{"type":21,"tag":39,"props":304,"children":305},{},[],{"type":21,"tag":22,"props":307,"children":308},{},[309,314],{"type":21,"tag":108,"props":310,"children":313},{"alt":311,"src":312},"Fifteenth Dish","/img/posts/2023/06/11/16.jpg",[],{"type":21,"tag":39,"props":315,"children":316},{},[],{"type":21,"tag":22,"props":318,"children":319},{},[320,325],{"type":21,"tag":108,"props":321,"children":324},{"alt":322,"src":323},"Sixteenth Dish","/img/posts/2023/06/11/17.jpg",[],{"type":21,"tag":39,"props":326,"children":327},{},[],{"type":21,"tag":22,"props":329,"children":330},{},[331,336],{"type":21,"tag":108,"props":332,"children":335},{"alt":333,"src":334},"Seventeenth Dish","/img/posts/2023/06/11/18.jpg",[],{"type":21,"tag":39,"props":337,"children":338},{},[],{"type":21,"tag":22,"props":340,"children":341},{},[342],{"type":26,"value":343},"The freshness of the ingredients is guaranteed, and each dish is incredibly flavorful.",{"type":21,"tag":22,"props":345,"children":346},{},[347],{"type":26,"value":348},"Midway through, the staff asked if we wanted to add extra lobster or wagyu beef, but since we estimated our portions just right, we declined additional orders.",{"type":21,"tag":22,"props":350,"children":351},{},[352],{"type":26,"value":353},"For the final main course, the restaurant prepares a seafood rice dish.",{"type":21,"tag":22,"props":355,"children":356},{},[357],{"type":26,"value":358},"If you’re still hungry, you can ask for more rice – the service is very considerate.",{"type":21,"tag":39,"props":360,"children":361},{},[],{"type":21,"tag":22,"props":363,"children":364},{},[365,370],{"type":21,"tag":108,"props":366,"children":369},{"alt":367,"src":368},"Eighteenth Dish","/img/posts/2023/06/11/19.jpg",[],{"type":21,"tag":39,"props":371,"children":372},{},[],{"type":21,"tag":22,"props":374,"children":375},{},[376],{"type":26,"value":377},"At the end of the meal, dessert is served, paired with matcha, perfectly concluding the dining experience.",{"type":21,"tag":39,"props":379,"children":380},{},[],{"type":21,"tag":22,"props":382,"children":383},{},[384,388],{"type":21,"tag":108,"props":385,"children":387},{"alt":367,"src":386},"/img/posts/2023/06/11/20.jpg",[],{"type":21,"tag":39,"props":389,"children":390},{},[],{"type":21,"tag":22,"props":392,"children":393},{},[394],{"type":26,"value":395},"The dessert is not overly sweet, and with the matcha, it tastes perfect.",{"type":21,"tag":22,"props":397,"children":398},{},[399],{"type":26,"value":400},"Overall, the food is exquisite, the ingredients are fresh, and the service is thoughtful. I highly recommend everyone to come and try it.",{"type":21,"tag":22,"props":402,"children":403},{},[404],{"type":26,"value":405},"Restaurant Name: Chuyu Sushi - Regent Hotel Taipei",{"type":21,"tag":22,"props":407,"children":408},{},[409,411],{"type":26,"value":410},"Address: ",{"type":21,"tag":51,"props":412,"children":416},{"className":413,"href":414,"rel":415},[54],"https://g.co/kgs/qMtEQUG",[57],[417],{"type":26,"value":418},"B2, No. 3, Lane 39, Section 2, Zhongshan North Road, Zhongshan District, Taipei City",{"type":21,"tag":22,"props":420,"children":421},{},[422],{"type":26,"value":423},"Reservation Hotline: (886)2-23660792 (10:00~21:00)",{"type":21,"tag":22,"props":425,"children":426},{},[427,429,436,439],{"type":26,"value":428},"Official Website: ",{"type":21,"tag":51,"props":430,"children":433},{"className":431,"href":84,"rel":432},[54],[57],[434],{"type":26,"value":435},"Link",{"type":21,"tag":39,"props":437,"children":438},{},[],{"type":21,"tag":39,"props":440,"children":441},{},[],{"title":7,"searchDepth":443,"depth":443,"links":444},2,[],"markdown","content:en:food:2023:06:11:chu-yu-omakase.md","content","en/food/2023/06/11/chu-yu-omakase.md","en/food/2023/06/11/chu-yu-omakase","md",{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"keywords":452,"body":453,"_type":445,"_id":446,"_source":447,"_file":448,"_stem":449,"_extension":450},[12,13,14,15,16],{"type":18,"children":454,"toc":795},[455,459,463,467,470,473,483,487,491,495,506,510,514,517,526,530,534,537,546,550,554,558,562,565,574,583,592,601,610,619,628,637,646,655,664,673,682,691,700,709,713,717,721,725,728,737,741,744,753,757,761,765,775,779],{"type":21,"tag":22,"props":456,"children":457},{},[458],{"type":26,"value":27},{"type":21,"tag":22,"props":460,"children":461},{},[462],{"type":26,"value":32},{"type"