/14.jpg",[],{"type":21,"tag":39,"props":301,"children":302},{},[],{"type":21,"tag":22,"props":304,"children":305},{},[306,311],{"type":21,"tag":46,"props":307,"children":310},{"alt":308,"src":309},"Fourteenth Dish","https://cdn.lucas-chen.website/2023/06/11/15.jpg",[],{"type":21,"tag":39,"props":312,"children":313},{},[],{"type":21,"tag":22,"props":315,"children":316},{},[317,322],{"type":21,"tag":46,"props":318,"children":321},{"alt":319,"src":320},"Fifteenth Dish","https://cdn.lucas-chen.website/2023/06/11/16.jpg",[],{"type":21,"tag":39,"props":323,"children":324},{},[],{"type":21,"tag":22,"props":326,"children":327},{},[328,333],{"type":21,"tag":46,"props":329,"children":332},{"alt":330,"src":331},"Sixteenth Dish","https://cdn.lucas-chen.website/2023/06/11/17.jpg",[],{"type":21,"tag":39,"props":334,"children":335},{},[],{"type":21,"tag":22,"props":337,"children":338},{},[339,344],{"type":21,"tag":46,"props":340,"children":343},{"alt":341,"src":342},"Seventeenth Dish","https://cdn.lucas-chen.website/2023/06/11/18.jpg",[],{"type":21,"tag":39,"props":345,"children":346},{},[],{"type":21,"tag":22,"props":348,"children":349},{},[350],{"type":26,"value":351},"The freshness of the ingredients is guaranteed, and each dish is incredibly flavorful.",{"type":21,"tag":22,"props":353,"children":354},{},[355],{"type":26,"value":356},"Midway through, the staff asked if we wanted to add extra lobster or wagyu beef, but since we estimated our portions just right, we declined additional orders.",{"type":21,"tag":22,"props":358,"children":359},{},[360],{"type":26,"value":361},"For the final main course, the restaurant prepares a seafood rice dish.",{"type":21,"tag":22,"props":363,"children":364},{},[365],{"type":26,"value":366},"If you’re still hungry, you can ask for more rice – the service is very considerate.",{"type":21,"tag":39,"props":368,"children":369},{},[],{"type":21,"tag":22,"props":371,"children":372},{},[373,378],{"type":21,"tag":46,"props":374,"children":377},{"alt":375,"src":376},"Eighteenth Dish","https://cdn.lucas-chen.website/2023/06/11/19.jpg",[],{"type":21,"tag":39,"props":379,"children":380},{},[],{"type":21,"tag":22,"props":382,"children":383},{},[384],{"type":26,"value":385},"At the end of the meal, dessert is served, paired with matcha, perfectly concluding the dining experience.",{"type":21,"tag":39,"props":387,"children":388},{},[],{"type":21,"tag":22,"props":390,"children":391},{},[392,396],{"type":21,"tag":46,"props":393,"children":395},{"alt":375,"src":394},"https://cdn.lucas-chen.website/2023/06/11/20.jpg",[],{"type":21,"tag":39,"props":397,"children":398},{},[],{"type":21,"tag":22,"props":400,"children":401},{},[402],{"type":26,"value":403},"The dessert is not overly sweet, and with the matcha, it tastes perfect.",{"type":21,"tag":22,"props":405,"children":406},{},[407],{"type":26,"value":408},"Overall, the food is exquisite, the ingredients are fresh, and the service is thoughtful. I highly recommend everyone to come and try it.",{"type":21,"tag":22,"props":410,"children":411},{},[412],{"type":26,"value":413},"Restaurant Name: Chuyu Sushi - Regent Hotel Taipei",{"type":21,"tag":22,"props":415,"children":416},{},[417,419],{"type":26,"value":418},"Address: ",{"type":21,"tag":60,"props":420,"children":424},{"className":421,"href":422,"rel":423},[63],"https://g.co/kgs/qMtEQUG",[66],[425],{"type":26,"value":426},"B2, No. 3, Lane 39, Section 2, Zhongshan North Road, Zhongshan District, Taipei City",{"type":21,"tag":22,"props":428,"children":429},{},[430],{"type":26,"value":431},"Reservation Hotline: (886)2-23660792 (10:00~21:00)",{"type":21,"tag":22,"props":433,"children":434},{},[435,437,444,447],{"type":26,"value":436},"Official Website: ",{"type":21,"tag":60,"props":438,"children":441},{"className":439,"href":93,"rel":440},[63],[66],[442],{"type":26,"value":443},"Link",{"type":21,"tag":39,"props":445,"children":446},{},[],{"type":21,"tag":39,"props":448,"children":449},{},[],{"title":7,"searchDepth":451,"depth":45