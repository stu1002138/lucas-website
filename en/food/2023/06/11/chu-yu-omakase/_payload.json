[{"data":1,"prerenderedAt":811},["ShallowReactive",2],{"doc":3,"content-query-iqgeCqomgo":459},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"keywords":11,"body":17,"_type":453,"_id":454,"_source":455,"_file":456,"_stem":457,"_extension":458},"/en/food/2023/06/11/chu-yu-omakase","11",false,"","Chu-yu - Japanese Omakase","Third Visit to Chuyu Sushi - A Japanese Omakase Restaurant in Taiwan.","2023-06-11T00:00:00.000Z",[12,13,14,15,16],"Food","Omakase","Japanese Cuisine","Chu-yu","Birthday Celebration",{"type":18,"children":19,"toc":450},"root",[20,28,33,38,42,54,70,75,80,85,100,105,110,113,124,129,134,137,148,153,158,163,168,171,182,193,204,215,226,237,248,259,270,281,292,303,314,325,336,347,352,357,362,367,370,381,386,389,399,404,409,414,427,432],{"type":21,"tag":22,"props":23,"children":24},"element","p",{},[25],{"type":26,"value":27},"text","This time, to celebrate my girlfriend's birthday,",{"type":21,"tag":22,"props":29,"children":30},{},[31],{"type":26,"value":32},"I specially booked this Japanese Omakase restaurant – Chuyu Sushi.",{"type":21,"tag":22,"props":34,"children":35},{},[36],{"type":26,"value":37},"This restaurant became a favorite of mine after a friend took me here for my birthday once, and I’ve remembered it ever since.",{"type":21,"tag":39,"props":40,"children":41},"br",{},[],{"type":21,"tag":22,"props":43,"children":44},{},[45,51],{"type":21,"tag":46,"props":47,"children":50},"img",{"alt":48,"src":49},"Restaurant Photo","https://scontent.ftpe14-1.fna.fbcdn.net/v/t39.30808-6/306085164_608610030967634_3901678845169237441_n.jpg?_nc_cat=106&ccb=1-7&_nc_sid=6ee11a&_nc_ohc=vwdLq4CScFEQ7kNvgGsEwgM&_nc_ht=scontent.ftpe14-1.fna&oh=00_AYDh52z3LSEPN5Fv3Q5DjR9nYw6-eC8ZS3Rq1f0NzW8yLA&oe=66D34150",[],{"type":21,"tag":39,"props":52,"children":53},{},[],{"type":21,"tag":22,"props":55,"children":56},{},[57,59],{"type":26,"value":58},"Image source: ",{"type":21,"tag":60,"props":61,"children":67},"a",{"className":62,"href":64,"rel":65},[63],"text-blue","https://www.facebook.com/chuyu.regent/",[66],"nofollow",[68],{"type":26,"value":69},"Chuyu Sushi - Regent Hotel",{"type":21,"tag":22,"props":71,"children":72},{},[73],{"type":26,"value":74},"Initially, the meal set at Chuyu Sushi was priced at TWD 1200 +10%.",{"type":21,"tag":22,"props":76,"children":77},{},[78],{"type":26,"value":79},"However, with inflation, the prices have increased as well.",{"type":21,"tag":22,"props":81,"children":82},{},[83],{"type":26,"value":84},"This restaurant is located in the B1 level of Regent Hotel Taipei, near Zhongshan MRT Station.",{"type":21,"tag":22,"props":86,"children":87},{},[88,90,98],{"type":26,"value":89},"Before dining, reservations must be made in advance through the ",{"type":21,"tag":60,"props":91,"children":95},{"className":92,"href":93,"rel":94},[63],"https://www.chu-yu.com.tw/",[66],[96],{"type":26,"value":97},"Chuyu Sushi official website",{"type":26,"value":99},".",{"type":21,"tag":22,"props":101,"children":102},{},[103],{"type":26,"value":104},"Full payment is required upfront, either via bank transfer or in-store credit card.",{"type":21,"tag":22,"props":106,"children":107},{},[108],{"type":26,"value":109},"Due to limited seating, I recommend booking early to secure your spot!",{"type":21,"tag":39,"props":111,"children":112},{},[],{"type":21,"tag":22,"props":114,"children":115},{},[116,121],{"type":21,"tag":46,"props":117,"children":120},{"alt":118,"src":119},"Seated","https://cdn.lucas-chen.website/2023/06/11/01.jpg",[],{"type":21,"tag":39,"props":122,"children":123},{},[],{"type":21,"tag":22,"props":125,"children":126},{},[127],{"type":26,"value":128},"Once seated, the staff will first serve a cup of hot tea, along with small appetizers and pickles.",{"type":21,"tag":22,"props":130,"children":131},{},[132],{"type":26,"value":133},"Then, the essence of Omakase slowly unfolds, with each dish meticulously crafted and served.",{"type":21,"tag":39,"props":135,"children":136},{},[],{"type":21,"tag":22,"props":138,"children":139},{},[140,145],{"type":21,"tag":46,"props":141,"children":144},{"alt":142,"src":143},"Appetizer","https://cdn.lucas-chen.website/2023/06/11/02.jpg",[],{"type":21,"tag":39,"props":146,"children":147},{},[],{"type":21,"tag":22,"props":149,"children":150},{},[151],{"type":26,"value":152},"The appetizer is refreshing and whets your appetite, preparing you for the culinary experience ahead.",{"type":21,"tag":22,"props":154,"children":155},{},[156],{"type":26,"value":157},"One by one, the dishes are served.",{"type":21,"tag":22,"props":159,"children":160},{},[161],{"type":26,"value":162},"Although I’ve forgotten most of the specific dish names due to the passage of time, I can confidently say that every dish was fresh and delicious, particularly the seafood used by the restaurant.",{"type":21,"tag":22,"props":164,"children":165},{},[166],{"type":26,"value":167},"Below are some of the dishes we enjoyed during the meal:",{"type":21,"tag":39,"props":169,"children":170},{},[],{"type":21,"tag":22,"props":172,"children":173},{},[174,179],{"type":21,"tag":46,"props":175,"children":178},{"alt":176,"src":177},"Second Dish","https://cdn.lucas-chen.website/2023/06/11/03.jpg",[],{"type":21,"tag":39,"props":180,"children":181},{},[],{"type":21,"tag":22,"props":183,"children":184},{},[185,190],{"type":21,"tag":46,"props":186,"children":189},{"alt":187,"src":188},"Third Dish","https://cdn.lucas-chen.website/2023/06/11/04.jpg",[],{"type":21,"tag":39,"props":191,"children":192},{},[],{"type":21,"tag":22,"props":194,"children":195},{},[196,201],{"type":21,"tag":46,"props":197,"children":200},{"alt":198,"src":199},"Fourth Dish","https://cdn.lucas-chen.website/2023/06/11/05.jpg",[],{"type":21,"tag":39,"props":202,"children":203},{},[],{"type":21,"tag":22,"props":205,"children":206},{},[207,212],{"type":21,"tag":46,"props":208,"children":211},{"alt":209,"src":210},"Fifth Dish","https://cdn.lucas-chen.website/2023/06/11/06.jpg",[],{"type":21,"tag":