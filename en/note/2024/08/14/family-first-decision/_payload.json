[{"data":1,"prerenderedAt":357},["ShallowReactive",2],{"doc":3,"content-query-q6QWgDdg7I":209},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"keywords":11,"body":18,"_type":203,"_id":204,"_source":205,"_file":206,"_stem":207,"_extension":208},"/en/note/2024/08/14/family-first-decision","14",false,"","Putting Family First: The Decision to Resign and What It Taught Me","Documenting my first time quitting a job after five years of work, reflecting on the balance between family and career.","2024-08-14T00:00:00.000Z",[12,13,14,15,16,17],"Work-Life Balance","Resignation Reflection","Family Health","Caring for Family","Personal Growth","Resignation Experience",{"type":19,"children":20,"toc":196},"root",[21,29,34,48,52,57,62,67,70,80,83,88,93,98,103,108,113,116,126,129,134,139,144,149,152,162,165,170,175,180,183],{"type":22,"tag":23,"props":24,"children":25},"element","p",{},[26],{"type":27,"value":28},"text","The sudden news of my family member being diagnosed with a lung tumor.",{"type":22,"tag":23,"props":30,"children":31},{},[32],{"type":27,"value":33},"Initially, she chose not to pursue further treatment since the tumor was small.",{"type":22,"tag":35,"props":36,"children":38},"h2",{"id":37},"the-turn-of-events",[39],{"type":22,"tag":40,"props":41,"children":45},"span",{"className":42},[43,44],"text-lg","font-bold",[46],{"type":27,"value":47},"The Turn of Events",{"type":22,"tag":49,"props":50,"children":51},"br",{},[],{"type":22,"tag":23,"props":53,"children":54},{},[55],{"type":27,"value":56},"At that time, I had just started a new job less than a year ago.",{"type":22,"tag":23,"props":58,"children":59},{},[60],{"type":27,"value":61},"The company was a startup, so the pace was actually faster than that of traditional companies.",{"type":22,"tag":23,"props":63,"children":64},{},[65],{"type":27,"value":66},"However, my family member's illness began to affect my ability to focus daily.",{"type":22,"tag":49,"props":68,"children":69},{},[],{"type":22,"tag":35,"props":71,"children":73},{"id":72},"the-conflict-between-family-and-work",[74],{"type":22,"tag":40,"props":75,"children":77},{"className":76},[43,44],[78],{"type":27,"value":79},"The Conflict Between Family and Work",{"type":22,"tag":49,"props":81,"children":82},{},[],{"type":22,"tag":23,"props":84,"children":85},{},[86],{"type":27,"value":87},"Due to my family member's physical weakness",{"type":22,"tag":23,"props":89,"children":90},{},[91],{"type":27,"value":92},"I had to take on all household chores and frequently take them to the doctor.",{"type":22,"tag":23,"props":94,"children":95},{},[96],{"type":27,"value":97},"The treatments were not showing significant improvement.",{"type":22,"tag":23,"props":99,"children":100},{},[101],{"type":27,"value":102},"During work, I often found myself thinking about what else I could do to help my family member recover more quickly.",{"type":22,"tag":23,"props":104,"children":105},{},[106],{"type":27,"value":107},"My mentor was highly capable and worked at a fast pace.",{"type":22,"tag":23,"props":109,"children":110},{},[111],{"type":27,"value":112},"As a result, the decline in my work quality quickly became apparent to my mentor.",{"type":22,"tag":49,"props":114,"children":115},{},[],{"type":22,"tag":35,"props":117,"children":119},{"id":118},"making-the-decision",[120],{"type":22,"tag":40,"props":121,"children":123},{"className":122},[43,44],[124],{"type":27,"value":125},"Making the Decision",{"type":22,"tag":49,"props":127,"children":128},{},[],{"type":22,"tag":23,"props":130,"children":131},{},[132],{"type":27,"value":133},"Faced with this situation, I ultimately decided to resign",{"type":22,"tag":23,"props":135,"children":136},{},[137],{"type":27,"value":138},"To focus on caring for my family",{"type":22,"tag":23,"props":140,"children":141},{},[142],{"type":27,"value":143},"Once my family member's health stabilizes, I will consider my next steps.",{"type":22,"tag":23,"props":145,"children":146},{},[147],{"type":27,"value":148},"I understand that work can be found again, but if I miss this chance to care for my family member's health, I might regret not making this decision.",{"type":22,"tag":49,"props":150,"children":151},{},[],{"type":22,"tag":35,"props":153,"children":155},{"id":154},"the-significance-of-resignation",[156],{"type":22,"tag":40,"props":157,"children":159},{"className":158},[43,44],[160],{"type":27,"value":161},"The Significance of Resignation",{"type":22,"tag":49,"props":163,"children":164},{},[],{"type":22,"tag":23,"props":166,"children":167},{},[168],{"type":27,"value":169},"This decision to resign is not only for my family but also for myself to take a much-needed break and work on the blog I've always wanted to complete.",{"type":22,"tag":23,"props":171,"children":172},{},[173],{"type":27,"value":174},"In the five years since I started working, I've always transitioned seamlessly between jobs, never having a true gap year.",{"type":22,"tag":23,"props":176,"children":177},{},[178],{"type":27,"value":179},"Now, this opportunity, born out of my family member's illness, allows me to recharge and better prepare for the next steps in my life.",{"type":22,"tag":49,"props":181,"children":182},{},[],{"type":22,"tag":184,"props":185,"children":186},"blockquote",{},[187],{"type":22,"tag":23,"props":188,"children":189},{},[190],{"type":22,"tag":191,"props":192,"children":193},"strong",{},[194],{"type":27,"value":195},"The right decisions are always the hardest to make. But they must be made in order to live the life you deserve.",{"title":7,"searchDepth":197,"depth":197,"links":198},2,[199,200,201,202],{"id":37,"depth":197,"text":47},{"id":72,"depth":197,"text":79},{"id":118,"depth":197,"text":125},{"id":154,"depth":197,"text":161},"markdown","content:en:note:2024:08:14:family-first-decision.md","content","en/note/2024/08/14/family-first-decision.md","en/note/2024/08/14/family-first-decision","md",{"_path":4,"_dir":5,"_draft":6,"_partial":6