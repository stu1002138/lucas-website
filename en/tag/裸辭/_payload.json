[{"data":1,"prerenderedAt":209},["ShallowReactive",2],{"tag-裸辭":3},[4],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"date":11,"keywords":12,"body":19,"_type":203,"_id":204,"_source":205,"_file":206,"_stem":207,"_extension":208},"/note/2024/08/14/family-first-decision","14",false,"","為家人停下腳步：因家人而辭職的思考與感悟","記錄一下工作五年後，第一次裸辭，以及思考家人與職場平衡。","2024-08-14T00:00:00.000Z",[13,14,15,16,17,18],"家庭與工作平衡","辭職思考","家人健康","照顧家人","個人成長","裸辭",{"type":20,"children":21,"toc":196},"root",[22,30,43,47,52,57,62,67,70,79,82,87,92,97,102,107,112,115,124,127,132,137,142,147,150,159,162,167,172,177,180,193],{"type":23,"tag":24,"props":25,"children":26},"element","p",{},[27],{"type":28,"value":29},"text","家人突然罹患肺部腫瘤的消息\n初期因為腫瘤不大而選擇不追蹤治療。",{"type":23,"tag":31,"props":32,"children":34},"h2",{"id":33},"事情的轉變",[35],{"type":23,"tag":36,"props":37,"children":41},"span",{"className":38},[39,40],"text-lg","font-bold",[42],{"type":28,"value":33},{"type":23,"tag":44,"props":45,"children":46},"br",{},[],{"type":23,"tag":24,"props":48,"children":49},{},[50],{"type":28,"value":51},"這時的我，才剛換工作不到一年",{"type":23,"tag":24,"props":53,"children":54},{},[55],{"type":28,"value":56},"公司是偏新創公司",{"type":23,"tag":24,"props":58,"children":59},{},[60],{"type":28,"value":61},"所以其實步調比傳統的公司還要快",{"type":23,"tag":24,"props":63,"children":64},{},[65],{"type":28,"value":66},"但家人得病情讓我每天專注度受到影響",{"type":23,"tag":44,"props":68,"children":69},{},[],{"type":23,"tag":31,"props":71,"children":73},{"id":72},"家庭與工作的矛盾",[74],{"type":23,"tag":36,"props":75,"children":77},{"className":76},[39,40],[78],{"type":28,"value":72},{"type":23,"tag":44,"props":80,"children":81},{},[],{"type":23,"tag":24,"props":83,"children":84},{},[85],{"type":28,"value":86},"家人因體力虛弱",{"type":23,"tag":24,"props":88,"children":89},{},[90],{"type":28,"value":91},"家事一定就是我包辦，就醫的次數頻繁",{"type":23,"tag":24,"props":93,"children":94},{},[95],{"type":28,"value":96},"治療又沒看到好轉",{"type":23,"tag":24,"props":98,"children":99},{},[100],{"type":28,"value":101},"工作時，總在思考，還有什麼方式能讓家人盡快好轉",{"type":23,"tag":24,"props":103,"children":104},{},[105],{"type":28,"value":106},"我的Mentor 能力強 步調快",{"type":23,"tag":24,"props":108,"children":109},{},[110],{"type":28,"value":111},"所以工作品質下滑，很快就讓Mentor察覺到了",{"type":23,"tag":44,"props":113,"children":114},{},[],{"type":23,"tag":31,"props":116,"children":118},{"id":117},"做出決定",[119],{"type":23,"tag":36,"props":120,"children":122},{"className":121},[39,40],[123],{"type":28,"value":117},{"type":23,"tag":44,"props":125,"children":126},{},[],{"type":23,"tag":24,"props":128,"children":129},{},[130],{"type":28,"value":131},"面對這情況，我最終決定離職",{"type":23,"tag":24,"props":133,"children":134},{},[135],{"type":28,"value":136},"專心照顧家人",{"type":23,"tag":24,"props":138,"children":139},{},[140],{"type":28,"value":141},"等到家人的健康穩定後，再考慮自己的下一步。",{"type":23,"tag":24,"props":143,"children":144},{},[145],{"type":28,"value":146},"我深知，工作可以再找，但家人的健康如果錯過了，可能會後悔沒有做出這個決定。",{"type":23,"tag":44,"props":148,"children":149},{},[],{"type":23,"tag":31,"props":151,"children":153},{"id":152},"離職的意義",[154],{"type":23,"tag":36,"props":155,"children":157},{"className":156},[39,40],[158],{"type":28,"value":152},{"type":23,"tag":44,"props":160,"children":161},{},[],{"type":23,"tag":24,"props":163,"children":164},{},[165],{"type":28,"value":166},"這次的離職決定，不僅是為了家人，也是為了自己能夠好好休息，並整理那個我一直想要完成的部落格。",{"type":23,"tag":24,"props":168,"children":169},{},[170],{"type":28,"value":171},"出社會五年來，工作轉換總是無縫接軌，我從未有過真正的gap year。",{"type":23,"tag":24,"props":173,"children":174},{},[175],{"type":28,"value":176},"現在，這個因家人生病而出現的機會，讓我得以為人生充電，為未來的每一步做更好的準備。",{"type":23,"tag":44,"props":178,"children":179},{},[],{"type":23,"tag":181,"props":182,"children":183},"blockquote",{},[184],{"type":23,"tag":24,"props":185,"children":186},{},[187],{"type":23,"tag":188,"props":189,"children":190},"strong",{},[191],{"type":28,"value":192},"The right decisions are always the hardest to make it. But they must be made in order to live the life you deserve.",{"type":23,"tag":44,"props":194,"children":195},{},[],{"title":8,"searchDepth":197,"depth":197,"links":198},2,[199,200,201,202],{"id":33,"depth":197,"text":33},{"id":72,"depth":197,"text":72},{"id":117,"depth":197,"text":117},{"id":152,"depth":197,"text":152},"markdown","content:note:2024:08:14:family-first-decision.md","content","note/2024/08/14/family-first-decision.md","note/2024/08/14/family-first-decision","md",1774340645825]