[{"data":1,"prerenderedAt":359},["ShallowReactive",2],{"doc":3,"content-query-uhUZCACvkS":208},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"keywords":11,"body":18,"_type":202,"_id":203,"_source":204,"_file":205,"_stem":206,"_extension":207},"/note/2024/08/14/family-first-decision","14",false,"","為家人停下腳步：因家人而辭職的思考與感悟","記錄一下工作五年後，第一次裸辭，以及思考家人與職場平衡。","2024-08-14T00:00:00.000Z",[12,13,14,15,16,17],"家庭與工作平衡","辭職思考","家人健康","照顧家人","個人成長","裸辭",{"type":19,"children":20,"toc":195},"root",[21,29,42,46,51,56,61,66,69,78,81,86,91,96,101,106,111,114,123,126,131,136,141,146,149,158,161,166,171,176,179,192],{"type":22,"tag":23,"props":24,"children":25},"element","p",{},[26],{"type":27,"value":28},"text","家人突然罹患肺部腫瘤的消息\n初期因為腫瘤不大而選擇不追蹤治療。",{"type":22,"tag":30,"props":31,"children":33},"h2",{"id":32},"事情的轉變",[34],{"type":22,"tag":35,"props":36,"children":40},"span",{"className":37},[38,39],"text-lg","font-bold",[41],{"type":27,"value":32},{"type":22,"tag":43,"props":44,"children":45},"br",{},[],{"type":22,"tag":23,"props":47,"children":48},{},[49],{"type":27,"value":50},"這時的我，才剛換工作不到一年",{"type":22,"tag":23,"props":52,"children":53},{},[54],{"type":27,"value":55},"公司是偏新創公司",{"type":22,"tag":23,"props":57,"children":58},{},[59],{"type":27,"value":60},"所以其實步調比傳統的公司還要快",{"type":22,"tag":23,"props":62,"children":63},{},[64],{"type":27,"value":65},"但家人得病情讓我每天專注度受到影響",{"type":22,"tag":43,"props":67,"children":68},{},[],{"type":22,"tag":30,"props":70,"children":72},{"id":71},"家庭與工作的矛盾",[73],{"type":22,"tag":35,"props":74,"children":76},{"className":75},[38,39],[77],{"type":27,"value":71},{"type":22,"tag":43,"props":79,"children":80},{},[],{"type":22,"tag":23,"props":82,"children":83},{},[84],{"type":27,"value":85},"家人因體力虛弱",{"type":22,"tag":23,"props":87,"children":88},{},[89],{"type":27,"value":90},"家事一定就是我包辦，就醫的次數頻繁",{"type":22,"tag":23,"props":92,"children":93},{},[94],{"type":27,"value":95},"治療又沒看到好轉",{"type":22,"tag":23,"props":97,"children":98},{},[99],{"type":27,"value":100},"工作時，總在思考，還有什麼方式能讓家人盡快好轉",{"type":22,"tag":23,"props":102,"children":103},{},[104],{"type":27,"value":105},"我的Mentor 能力強 步調快",{"type":22,"tag":23,"props":107,"children":108},{},[109],{"type":27,"value":110},"所以工作品質下滑，很快就讓Mentor察覺到了",{"type":22,"tag":43,"props":112,"children":113},{},[],{"type":22,"tag":30,"props":115,"children":117},{"id":116},"做出決定",[118],{"type":22,"tag":35,"props":119,"children":121},{"className":120},[38,39],[122],{"type":27,"value":116},{"type":22,"tag":43,"props":124,"children":125},{},[],{"type":22,"tag":23,"props":127,"children":128},{},[129],{"type":27,"value":130},"面對這情況，我最終決定離職",{"type":22,"tag":23,"props":132,"children":133},{},[134],{"type":27,"value":135},"專心照顧家人",{"type":22,"tag":23,"props":137,"children":138},{},[139],{"type":27,"value":140},"等到家人的健康穩定後，再考慮自己的下一步。",{"type":22,"tag":23,"props":142,"children":143},{},[144],{"type":27,"value":145},"我深知，工作可以再找，但家人的健康如果錯過了，可能會後悔沒有做出這個決定。",{"type":22,"tag":43,"props":147,"children":148},{},[],{"type":22,"tag":30,"props":150,"children":152},{"id":151},"離職的意義",[153],{"type":22,"tag":35,"props":154,"children":156},{"className":155},[38,39],[157],{"type":27,"value":151},{"type":22,"tag":43,"props":159,"children":160},{},[],{"type":22,"tag":23,"props":162,"children":163},{},[164],{"type":27,"value":165},"這次的離職決定，不僅是為了家人，也是為了自己能夠好好休息，並整理那個我一直想要完成的部落格。",{"type":22,"tag":23,"props":167,"children":168},{},[169],{"type":27,"value":170},"出社會五年來，工作轉換總是無縫接軌，我從未有過真正的gap year。",{"type":22,"tag":23,"props":172,"children":173},{},[174],{"type":27,"value":175},"現在，這個因家人生病而出現的機會，讓我得以為人生充電，為未來的每一步做更好的準備。",{"type":22,"tag":43,"props":177,"children":178},{},[],{"type":22,"tag":180,"props":181,"children":182},"blockquote",{},[183],{"type":22,"tag":23,"props":184,"children":185},{},[186],{"type":22,"tag":187,"props":188,"children":189},"strong",{},[190],{"type":27,"value":191},"The right decisions are always the hardest to make it. But they must be made in order to live the life you deserve.",{"type":22,"tag":43,"props":193,"children":194},{},[],{"title":7,"searchDepth":196,"depth":196,"links":197},2,[198,199,200,201],{"id":32,"depth":196,"text":32},{"id":71,"depth":196,"text":71},{"id":116,"depth":196,"text":116},{"id":151,"depth":196,"text":151},"markdown","content:note:2024:08:14:family-first-decision.md","content","note/2024/08/14/family-first-decision.md","note/2024/08/14/family-first-decision","md",{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"keywords":209,"body":210,"_type":202,"_id":203,"_source":204,"_file":205,"_stem":206,"_extension":207},[12,13,14,15,16,17],{"type":19,"children":211,"toc":353},[212,216,224,227,231,235,239,243,246,254,257,261,265,269,273,277,281,284,292,295,299,303,307,311,314,322,325,329,333,337,340,350],{"type":22,"tag":23,"props":213,"children":214},{},[215],{"type":27,"value":28},{"type":22,"tag":30,"props":217,"children":218},{"id":32},[219],{"type":22,"tag":35,"props":220,"children":222},{"className":221},[38,39],[223],{"type":27,"value":32},{"type":22,"tag":43,"props":225,"children":226},{},[],{"type":22,"tag":23,"props":228,"children":229},{},[230],{"type":27,"value":50},{"type":22,"tag":23,"props":232,"children":233},{},[234],{"type":27,"value":55},{"type":22,"tag":23,"props":236,"children":237},{},[238],{"type":27,"value":60},{"type":22,"tag":23,"props":240,"children":241},{},[242],{"type":27,"value":65},{"type":22,"tag":43,"props":244,"children":245},{},[],{"type":22,"tag":30,"props":247,"children":248},{"id":71},[249],{"type":22,"tag":35,"props":250,"children":252},{"className":251},[38,39],[253],{"type":27,"value":71},{"type":22,"tag":43,"props":255,"children":256},{},[],{"type":22,"tag":23,"props":258,"children":259},{},[260],{"type":27,"value":85},{"type":22,"tag":23,"props":262,"children":263},{},[264],{"type":27,"value":90},{"type":22,"tag":23,"props":266,"children":267},{},[268],{"type":27,"value":95},{"type":22,"tag":23,"props":270,"children":