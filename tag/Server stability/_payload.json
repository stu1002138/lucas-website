[{"data":1,"prerenderedAt":500},["ShallowReactive",2],{"tag-Server stability":3},[4],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"date":11,"keywords":12,"body":18,"_type":494,"_id":495,"_source":496,"_file":497,"_stem":498,"_extension":499},"/en/tech-dev/2024/08/26/cdn-content-delivery-network","26",false,"","Exploring the Functionality and Applications of Content Delivery Network (CDN)","Introducing the CDN architecture, functions and application scenarios, as well as implementation examples.","2024-08-26T00:00:00.000Z",[13,14,15,16,17],"Content Delivery Network","CDN advantages","Web acceleration","Server stability","Edge nodes",{"type":19,"children":20,"toc":488},"root",[21,29,43,47,52,57,62,65,77,82,97,107,110,115,120,125,130,153,158,161,172,177,182,187,192,197,202,225,228,236,239,249,254,259,262,273,284,295,300,305,310,313,324,335,346,357,362,370,381,392,403,408,413,416,427,432,437,442,447,452,457,468,473,478,483],{"type":22,"tag":23,"props":24,"children":25},"element","p",{},[26],{"type":27,"value":28},"text","This article discusses the differences between traditional website setups and those using CDN, as well as the structure of CDN and practical application demonstrations.",{"type":22,"tag":30,"props":31,"children":33},"h2",{"id":32},"traditional-website-setup",[34],{"type":22,"tag":35,"props":36,"children":40},"span",{"className":37},[38,39],"text-lg","font-bold",[41],{"type":27,"value":42},"Traditional Website Setup",{"type":22,"tag":44,"props":45,"children":46},"br",{},[],{"type":22,"tag":23,"props":48,"children":49},{},[50],{"type":27,"value":51},"In traditional website setups, website content is hosted on a single server.",{"type":22,"tag":23,"props":53,"children":54},{},[55],{"type":27,"value":56},"When a user clicks on a URL in their browser, it connects to DNS, which translates the URL into the website's IP address.",{"type":22,"tag":23,"props":58,"children":59},{},[60],{"type":27,"value":61},"The browser then connects directly to that server to retrieve website content.",{"type":22,"tag":44,"props":63,"children":64},{},[],{"type":22,"tag":23,"props":66,"children":67},{},[68,74],{"type":22,"tag":69,"props":70,"children":73},"img",{"alt":71,"src":72},"Traditional Website Process","https://cdn.lucas-chen.website/2024/08/26/01.png",[],{"type":22,"tag":44,"props":75,"children":76},{},[],{"type":22,"tag":23,"props":78,"children":79},{},[80],{"type":27,"value":81},"This method has the following disadvantages:",{"type":22,"tag":83,"props":84,"children":85},"ul",{},[86,92],{"type":22,"tag":87,"props":88,"children":89},"li",{},[90],{"type":27,"value":91},"The farther away a user is from the server, the slower the speed (especially for global websites).",{"type":22,"tag":87,"props":93,"children":94},{},[95],{"type":27,"value":96},"Server stability is reduced (high traffic and multiple simultaneous connections to the same server increase the chance of a server crash).",{"type":22,"tag":30,"props":98,"children":100},{"id":99},"introduction-to-cdn",[101],{"type":22,"tag":35,"props":102,"children":104},{"className":103},[38,39],[105],{"type":27,"value":106},"Introduction to CDN",{"type":22,"tag":44,"props":108,"children":109},{},[],{"type":22,"tag":23,"props":111,"children":112},{},[113],{"type":27,"value":114},"This led to the development of CDN.",{"type":22,"tag":23,"props":116,"children":117},{},[118],{"type":27,"value":119},"CDN stands for Content Delivery Network.",{"type":22,"tag":23,"props":121,"children":122},{},[123],{"type":27,"value":124},"It allows website content to be deployed to edge nodes at various locations.",{"type":22,"tag":23,"props":126,"children":127},{},[128],{"type":27,"value":129},"Users from different regions can access the nearest server to retrieve content, providing several advantages:",{"type":22,"tag":83,"props":131,"children":132},{},[133,138,143,148],{"type":22,"tag":87,"props":134,"children":135},{},[136],{"type":27,"value":137},"Faster load times (reducing physical distance).",{"type":22,"tag":87,"props":139,"children":140},{},[141],{"type":27,"value":142},"Reduced load on the main server (users access the nearest CDN server, decreasing the load on the origin server).",{"type":22,"tag":87,"props":144,"children":145},{},[146],{"type":27,"value":147},"Improved reliability (multiple CDN servers reduce the risk of downtime).",{"type":22,"tag":87,"props":149,"children":150},{},[151],{"type":27,"value":152},"Enhanced user experience (faster connection speeds, quicker website browsing, and reduced risk of site crashes).",{"type":22,"tag":23,"props":154,"children":155},{},[156],{"type":27,"value":157},"CDN Process Diagram:",{"type":22,"tag":44,"props":159,"children":160},{},[],{"type":22,"tag":23,"props":162,"children":163},{},[164,169],{"type":22,"tag":69,"props":165,"children":168},{"alt":166,"src":167},"CDN Process Diagram","https://cdn.lucas-chen.website/2024/08/26/02.png",[],{"type":22,"tag":44,"props":170,"children":171},{},[],{"type":22,"tag":23,"props":173,"children":174},{},[175],{"type":27,"value":176},"Website content is stored on the primary server.",{"type":22,"tag":23,"props":178,"children":179},{},[180],{"type":27,"value":181},"After configuring CDN, when users connect to the website, they first connect to DNS.",{"type":22,"tag":23,"props":183,"children":184},{},[185],{"type":27,"value":186},"DNS then redirects to CDN DNS.",{"type":22,"tag":23,"props":188,"children":189},{},[190],{"type":27,"value":191},"CDN DNS identifies the user’s location and returns the IP of the closest CDN edge server.",{"type":22,"tag":23,"props":193,"children":194},{},[195],{"type":27,"value":196},"The user connects to the nearest CDN edge server to retrieve website content.",{"type":22,"tag":23,"props":198,"children":199},{},[200],{"type":27,"value":201},"CDN is composed of the following:",{"type":22,"tag":83,"props":203,"children":204},{},[205,210,215,220],{"type":22,"tag":87,"props":206,"children":207},{},[208],{"type":27,"value":209},"Primary content server (Origin Server)",{"type":22,"tag":87,"props":211,"children":212},{},[213],{"type":27,"value":214},"DNS",{"type":22,"tag":87,"props":216,"children":217},{},[218],{"type":27,"value":219},"CDN DNS",{"type":22,"tag":87,"props":221,"children":222},{},[223],{"type":27,"value":224},"CDN edge servers (CDN servers distributed across different regions)",{"type":22,"tag":44,"props":226,"children":227},{},[],{"type":22,"tag":23,"props":229,"children":230},{},[231],{"type":22,"tag":69,"props":232,"children":235},{"alt":233,"src":234},"CDN composed","https://cdn.lucas-chen.website/2024/08/26/03.png",[],{"type":22,"tag":44,"props":237,"children":238},{},[],{"type":22,"tag":30,"props":240,"children":242},{"id":241},"practical-demonstration",[243],{"type":22,"tag":35,"props":244,"children":246},{"className":245},[38,39],[247],{"type":27,"value":248},"Practical Demonstration",{"type":22,"tag":23,"props":250,"children":251},{},[252],{"type":27,"value":253},"I uploaded several large GIF files to a test website and placed them far from Taiwan.",{"type":22,"tag":23,"props":255,"children":256},{},[257],{"type":27,"value":258},"Then I tested the load speed for the first time.",{"type":22,"tag":44,"props":260,"children":261},{},[],{"type":22,"tag":23,"props":263,"children":264},{},[265,270],{"type":22,"tag":69,"props":266,"children":269},{"alt":267,"src":268},"CDN Demo1","https://cdn.lucas-chen.website/2024/08/26/04.png",[],{"type":22,"tag":44,"props":271,"children":272},{},[],{"type":22,"tag":23,"props":274,"children":275},{},[276,281],{"type":22,"tag":69,"props":277,"children":280},{"alt":278,"src":279},"CDN Demo2","https://cdn.lucas-chen.website/2024/08/26/05.png",[],{"type":22,"tag":44,"props":282,"children":283},{},[],{"type":22,"tag":23,"props":285,"children":286},{},[287,292],{"type":22,"tag":69,"props":288,"children":291},{"alt":289,"src":290},"CDN Demo3","https://cdn.lucas-chen.website/2024/08/26/06.png",[],{"type":22,"tag":44,"props":293,"children":294},{},[],{"type":22,"tag":23,"props":296,"children":297},{},[298],{"type":27,"value":299},"It took almost 3 seconds to load the images.",{"type":22,"tag":23,"props":301,"children":302},{},[303],{"type":27,"value":304},"Then I set up CDN.",{"type":22,"tag":23,"props":306,"children":307},{},[308],{"type":27,"value":309},"I used Cloudflare as the CDN service provider since they offer a free plan.",{"type":22,"tag":44,"props":311,"children":312},{},[],{"type":22,"tag":23,"props":314,"children":315},{},[316,321],{"type":22,"tag":69,"props":317,"children":320},{"alt":318,"src":319},"CDN Demo4","https://cdn.lucas-chen.website/2024/08/26/07.png",[],{"type":22,"tag":44,"props":322,"children":323},{},[],{"type":22,"tag":23,"props":325,"children":326},{},[327,332],{"type":22,"tag":69,"props":328,"children":331},{"alt":329,"src":330},"CDN Demo5","https://cdn.lucas-chen.website/2024/08/26/08.png",[],{"type":22,"tag":44,"props":333,"children":334},{},[],{"type":22,"tag":23,"props":336,"children":337},{},[338,343],{"type":22,"tag":69,"props":339,"children":342},{"alt":340,"src":341},"CDN Demo6","https://cdn.lucas-chen.website/2024/08/26/09.png",[],{"type":22,"tag":44,"props":344,"children":345},{},[],{"type":22,"tag":23,"props":347,"children":348},{},[349,354],{"type":22,"tag":69,"props":350,"children":353},{"alt":351,"src":352},"CDN Demo7","https://cdn.lucas-chen.website/2024/08/26/10.png",[],{"type":22,"tag":44,"props":355,"children":356},{},[],{"type":22,"tag":23,"props":358,"children":359},{},[360],{"type":27,"value":361},"After configuring, there are two main CDN DNS settings required by your domain registrar.",{"type":22,"tag":23,"props":363,"children":364},{},[365,367],{"type":27,"value":366},"I purchased my domain on Gandi, so I need to configure the domain’s name servers there.\n",{"type":22,"tag":44,"props":368,"children":369},{},[],{"type":22,"tag":23,"props":371,"children":372},{},[373,378],{"type":22,"tag":69,"props":374,"children":377},{"alt":375,"src":376},"CDN Demo8","https://cdn.lucas-chen.website/2024/08/26/11.png",[],{"type":22,"tag":44,"props":379,"children":380},{},[],{"type":22,"tag":23,"props":382,"children":383},{},[384,389],{"type":22,"tag":69,"props":385,"children":388},{"alt":386,"src":387},"CDN Demo9","https://cdn.lucas-chen.website/2024/08/26/12.png",[],{"type":22,"tag":44,"props":390,"children":391},{},[],{"type":22,"tag":23,"props":393,"children":394},{},[395,400],{"type":22,"tag":69,"props":396,"children":399},{"alt":397,"src":398},"CDN Demo10","https://cdn.lucas-chen.website/2024/08/26/13.png",[],{"type":22,"tag":44,"props":401,"children":402},{},[],{"type":22,"tag":23,"props":404,"children":405},{},[406],{"type":27,"value":407},"Once configured, it looks like this.",{"type":22,"tag":23,"props":409,"children":410},{},[411],{"type":27,"value":412},"After enabling the CDN, you can observe the significant improvement in loading speed.",{"type":22,"tag":44,"props":414,"children":415},{},[],{"type":22,"tag":23,"props":417,"children":418},{},[419,424],{"type":22,"tag":69,"props":420,"children":423},{"alt":421,"src":422},"CDN Demo11","https://cdn.lucas-chen.website/2024/08/26/14.png",[],{"type":22,"tag":44,"props":425,"children":426},{},[],{"type":22,"tag":23,"props":428,"children":429},{},[430],{"type":27,"value":431},"Compared to not using CDN, where each image took almost 3 seconds to load, with CDN, each image now loads in less than 200 milliseconds.",{"type":22,"tag":23,"props":433,"children":434},{},[435],{"type":27,"value":436},"The speed has increased significantly.",{"type":22,"tag":23,"props":438,"children":439},{},[440],{"type":27,"value":441},"How do I check if the website is using CDN?",{"type":22,"tag":23,"props":443,"children":444},{},[445],{"type":27,"value":446},"You can add cdn-cgi/trace to the end of the URL.",{"type":22,"tag":23,"props":448,"children":449},{},[450],{"type":27,"value":451},"You’ll see something like colo=KHH, indicating that it’s connected to the Kaohsiung CDN edge server.",{"type":22,"tag":23,"props":453,"children":454},{},[455],{"type":27,"value":456},"For users in Taipei, connecting to Kaohsiung speeds up the connection significantly!",{"type":22,"tag":23,"props":458,"children":459},{},[460,465],{"type":22,"tag":69,"props":461,"children":464},{"alt":462,"src":463},"CDN Demo12","https://cdn.lucas-chen.website/2024/08/26/15.png",[],{"type":22,"tag":44,"props":466,"children":467},{},[],{"type":22,"tag":23,"props":469,"children":470},{},[471],{"type":27,"value":472},"CDN isn’t just for websites; it’s also used for video streaming, software downloads, and game image and video acceleration.",{"type":22,"tag":23,"props":474,"children":475},{},[476],{"type":27,"value":477},"CDN helps improve speed and enhances the user experience.",{"type":22,"tag":23,"props":479,"children":480},{},[481],{"type":27,"value":482},"If there are any parts I missed, feel free to add suggestions.",{"type":22,"tag":23,"props":484,"children":485},{},[486],{"type":27,"value":487},"Thank you all!",{"title":8,"searchDepth":489,"depth":489,"links":490},2,[491,492,493],{"id":32,"depth":489,"text":42},{"id":99,"depth":489,"text":106},{"id":241,"depth":489,"text":248},"markdown","content:en:tech-dev:2024:08:26:cdn-content-delivery-network.md","content","en/tech-dev/2024/08/26/cdn-content-delivery-network.md","en/tech-dev/2024/08/26/cdn-content-delivery-network","md",1774333784920]