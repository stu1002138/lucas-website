68},"https://cdn.lucas-chen.website/2023/11/23/02.jpg",[],{"type":24,"tag":39,"props":71,"children":72},{},[],{"type":24,"tag":25,"props":74,"children":76},{"id":75},"抵達澳門",[77],{"type":24,"tag":30,"props":78,"children":80},{"className":79},[33,34],[81],{"type":37,"value":75},{"type":24,"tag":39,"props":83,"children":84},{},[],{"type":24,"tag":43,"props":86,"children":87},{},[88],{"type":37,"value":89},"抵達澳門後，發現機場附近有許多酒店的接駁車，完全不需要 Taxi 就能輕鬆抵達酒店。我們入住的是新濠影匯。",{"type":24,"tag":39,"props":91,"children":92},{},[],{"type":24,"tag":43,"props":94,"children":95},{},[96],{"type":24,"tag":55,"props":97,"children":100},{"alt":98,"src":99},"搭酒店接駁車","https://cdn.lucas-chen.website/2023/11/23/03.jpg",[],{"type":24,"tag":39,"props":102,"children":103},{},[],{"type":24,"tag":43,"props":105,"children":106},{},[107],{"type":37,"value":108},"酒店外觀 （車上拍的，有點糊）",{"type":24,"tag":39,"props":110,"children":111},{},[],{"type":24,"tag":43,"props":113,"children":114},{},[115],{"type":24,"tag":55,"props":116,"children":119},{"alt":117,"src":118},"酒店外觀","https://cdn.lucas-chen.website/2023/11/23/04.jpg",[],{"type":24,"tag":39,"props":121,"children":122},{},[],{"type":24,"tag":43,"props":124,"children":125},{},[126],{"type":37,"value":127},"入住後，雖然房間不算奢華，但非常舒適，還能看到對面的巴黎鐵塔，彷彿置身於巴黎，令人感到驚喜。",{"type":24,"tag":39,"props":129,"children":130},{},[],{"type":24,"tag":43,"props":132,"children":133},{},[134],{"type":24,"tag":55,"props":135,"children":138},{"alt":136,"src":137},"房間照片","https://cdn.lucas-chen.website/2023/11/23/05.jpg",[],{"type":24,"tag":39,"props":140,"children":141},{},[],{"type":24,"tag":43,"props":143,"children":144},{},[145],{"type":24,"tag":55,"props":146,"children":148},{"alt":136,"src":147},"https://cdn.lucas-chen.website/2023/11/23/06.jpg",[],{"type":24,"tag":39,"props":150,"children":151},{},[],{"type":24,"tag":43,"props":153,"children":154},{},[155],{"type":37,"value":156},"Check-in完畢後",{"type":24,"tag":43,"props":158,"children":159},{},[160],{"type":37,"value":161},"就要去補充體力 吃點東西拉",{"type":24,"tag":43,"props":163,"children":164},{},[165],{"type":37,"value":166},"我們是出去酒店外面 搭外面的 Taxi",{"type":24,"tag":43,"props":168,"children":169},{},[170],{"type":37,"value":171},"到比較多吃的酒店覓食",{"type":24,"tag":43,"props":173,"children":174},{},[175],{"type":37,"value":176},"因為我們到澳門已經很晚了",{"type":24,"tag":43,"props":178,"children":179},{},[180],{"type":37,"value":181},"新濠影匯的餐廳都已經關了",{"type":24,"tag":43,"props":183,"children":184},{},[185],{"type":37,"value":186},"所以我們查到澳門銀河酒店",{"type":24,"tag":43,"props":188,"children":189},{},[190],{"type":37,"value":191},"裡面餐廳還有營業",{"type":24,"tag":43,"props":193,"children":194},{},[195],{"type":37,"value":196},"所以就去裡面找評價不錯的餐廳吃晚餐了",{"type":24,"tag":43,"props":198,"children":199},{},[200],{"type":37,"value":201},"最後選到一間 翠華茶餐廳",{"type":24,"tag":43,"props":203,"children":204},{},[205],{"type":37,"value":206},"旁邊就賭場",{"type":24,"tag":43,"props":208,"children":209},{},[210],{"type":37,"value":211},"很多賭客賭完後來餐廳覓食",{"type":24,"tag":43,"props":213,"children":214},{},[215],{"type":37,"value":216},"看完菜單",{"type":24,"tag":43,"props":218,"children":219},{},[220],{"type":37,"value":221},"澳門消費真不是普通的高",{"type":24,"tag":43,"props":223,"children":224},{},[225],{"type":37,"value":226},"跟台灣物價來比，真的高不少",{"type":24,"tag":43,"props":228,"children":229},{},[230],{"type":37,"value":231},"兩個人只點了兩個魚蛋麵 兩杯奶茶  花了165 澳門幣 (約650台幣)",{"type":24,"tag":39,"props":233,"children":234},{},[],{"type":24,"tag":43,"props":236,"children":237},{},[238],{"type":24,"tag":55,"props":239,"children":242},{"alt":240,"src":241},"第一天晚餐","https://cdn.lucas-chen.website/2023/11/23/07.jpg",[],{"type":24,"tag":39,"props":244,"children":245},{},[],{"type":24,"tag":43,"props":247,"children":248},{},[249],{"type":37,"value":250},"晚餐後，我們隨意逛了逛賭場。賭桌的最低下注額為 300-500 港幣，對於小資族來說壓力頗大，所以我們決定試試老虎機。一百港幣很快輸光，但賭場內有免費飲料供應，至少這點還不錯（笑）。",{"type":24,"tag":43,"props":252,"children":253},{},[254],{"type":37,"value":255},"結束後就回酒店梳洗睡覺了",{"type":24,"tag":39,"props":257,"children":258},{},[],{"type":24,"tag":25,"props":260,"children":262},{"id":261},"第二天",[263],{"type":24,"tag":30,"props":264,"children":266},{"className":265},[33,34],[267],{"type":37,"value":261},{"type":24,"tag":39,"props":269,"children":270},{},[],{"type":24,"tag":43,"props":272,"children":273},{},[274],{"type":37,"value":275},"第二天我們主要行程是在新濠酒店裡面水上樂園玩",{"type":24,"tag":43,"props":277,"children":278},{},[279],{"type":37,"value":280},"所以我們就沒有跑太遠",{"type":24,"tag":43,"props":282,"children":283},{},[284],{"type":37,"value":285},"就先去 氹仔市中心 晃晃 吃午餐",{"type":24,"tag":39,"props":287,"children":288},{},[],{"type":24,"tag":43,"props":290,"children":291},{},[292],{"type":24,"tag":55,"props":293,"children":296},{"alt":294,"src":295},"搭車","https://cdn.lucas-chen.website/2023/11/23/1294217.jpg",[],{"type":24,"tag":39,"props":298,"children":299},{},[],{"type":24,"tag":43,"props":301,"children":302},{},[303],{"type":37,"value":304},"到市中心後看到這個咖哩牛雜",{"type":24,"tag":43,"props":306,"children":307},{},[308],{"type":37,"value":309},"評價不錯，我們就先點一碗來吃",{"type":24,"tag":43,"props":311,"children":312},{},[313],{"type":37,"value":314},"價格 不便宜啊！",{"type":24,"tag":39,"props":316,"children":317},{},[],{"type":24,"tag":43,"props":319,"children":320},{},[321],{"type":24,"tag":55,"props":322,"children":325},{"alt":323,"src":324},"吃咖哩牛雜","https://cdn.lucas-chen.website/2023/11/23/09.jpg",[],{"type":24,"tag":39,"props":327,"children":328},{},[],{"type":24,"tag":43,"props":330,"children":331},{},[332],{"type":37,"value":333},"吃完牛雜",{"type":24,"tag":43,"props":335,"children":336},{},[337],{"type":37,"value":338},"又去吃當地最有名的水蟹粥",{"type":24,"tag":43,"props":340,"children":341},{},[342],{"type":37,"value":343},"我覺得水蟹粥雖然美味，卻沒有特別驚艷。",{"type":24,"tag":39,"props":345,"children":346},{},[],{"type":24,"tag":43,"props":348,"children":349},{},[350],{"type":24,"tag":55,"props":351,"children":354},{"alt":352,"src":353},"水蟹粥菜餚1","https://cdn.lucas-chen.website/2023/11/23/11.jpg",[],{"type":24,"tag":39,"props":356,"children":357},{},[],{"type":24,"tag":43,"props":359,"children":360},{},[361],{"type":24,"tag":55,"props":362,"children":365},{"alt":363,"src":364},"水蟹粥菜餚2","https://cdn.lucas-chen.website/2023/11/23/12.jpg",[],{"type":24,"tag":39,"props":367,"children":368},{},[],{"type":24,"tag":43,"props":370,"children":371},{},[372],{"type":24,"tag":55,"props":373,"children":376},{"alt":374,"src":375},"得獎","https://cdn.lucas-chen.website/2023/11/23/13.jpg",[],{"type":24,"tag":39,"props":378,"children":379},{},[],{"type":24,"tag":43,"props":381,"children":382},{},[383],{"type":37,"value":384},"吃完差不多後",{"type":24,"tag":43,"props":386,"children":387},{},[388],{"type":37,"value":389},"就去喝飲料",{"type":24,"tag":43,"props":391,"children":392},{},[393],{"type":37,"value":394},"就去當地也蠻有名的",{"type":24,"tag":43,"props":396,"children":397},{},[398],{"type":37,"value":399},"旺記咖啡",{"type":24,"tag":39,"props":401,"children":402},{},[],{"type":24,"tag":43,"props":404,"children":405},{},[406],{"type":24,"tag":55,"props":407,"children":409},{"alt":399,"src":408},"https://cdn.lucas-chen.website/2023/11/23/1294222.jpg",[],{"type":24,"tag":39,"props":411,"children":412},{},[],{"type":24,"tag":43,"props":414,"children":415},{},[416],{"type":24,"tag":55,"props":417,"children":420},{"alt":418,"src":419},"旺記咖啡 附近拍照","https://cdn.lucas-chen.website/2023/11/23/10.jpg",[],{"type":24,"tag":39,"props":422,"children":423},{},[],{"type":24,"tag":43,"props":425,"children":426},{},[427],{"type":37,"value":428},"然後就在附近逛了一下",{"type":24,"tag":43,"props":430,"children":431},{},[432],{"type":37,"value":433},"就準備去 新濠影匯 的水上樂園",{"type":24,"tag":43,"props":435,"children":436},{},[437],{"type":37,"value":438},"因為 11 月的關係，只能玩室內部分，但即便如此，也算是相當有趣的一次體驗。只是因為無法戴蛙鏡，有些設施看不太清，稍微影響了玩樂的效果。",{"type":24,"tag":39,"props":440,"children":441},{},[],{"type":24,"tag":43,"props":443,"children":444},{},[445],{"type":24,"tag":55,"props":446,"children":449},{"alt":447,"src":448},"水上樂園","https://cdn.lucas-chen.website/2023/11/23/14.jpg",[],{"type":24,"tag":39,"props":451,"children":452},{},[],{"type":24,"tag":43,"props":454,"children":455},{},[456],{"type":37,"value":457},"所以我玩幾個設施後就因為看不太到",{"type":24,"tag":43,"props":459,"children":460},{},[461],{"type":37,"value":462},"有點暈",{"type":24,"tag":43,"props":464,"children":465},{},[466],{"type":37,"value":467},"蠻可惜的",{"type":24,"tag":43,"props":469,"children":470},{},[471],{"type":37,"value":472},"水上樂園結束後",{"type":24,"tag":43,"props":474,"children":475},{},[476],{"type":37,"value":477},"就去吃晚餐",{"type":24,"tag":43,"props":479,"children":480},{},[481],{"type":37,"value":482},"晚餐吃了港式飲茶",{"type":24,"tag":43,"props":484,"children":485},{},[486],{"type":37,"value":487},"中規中矩",{"type":24,"tag":43,"props":489,"children":490},{},[491],{"type":37,"value":492},"但吃了兩千元....",{"type":24,"tag":39,"props":494,"children":495},{},[],{"type":24,"tag":43,"props":497,"children":498},{},[499],{"type":24,"tag":55,"props":500,"children":503},{"alt":501,"src":502},"港式飲茶","https://cdn.lucas-chen.website/2023/11/23/22.jpg",[],{"type":24,"tag":39,"props":505,"children":506},{},[],{"type":24,"tag":43,"props":508,"children":509},{},[510],{"type":37,"value":511},"晚餐後，我們決定去各大賭場踩點，每個賭場的裝潢都金碧輝煌，真不愧是賭城！雖然沒有大手筆下注，但這些華麗的場景讓人印象深刻。",{"type":24,"tag":39,"props":513,"children":514},{},[],{"type":24,"tag":43,"props":516,"children":517},{},[518],{"type":24,"tag":55,"props":519,"children":522},{"alt":520,"src":521},"賭場1","https://cdn.lucas-chen.website/2023/11/23/15.jpg",[],{"type":24,"tag":39,"props":524,"children":525},{},[],{"type":24,"tag":43,"props":527,"children":528},{},[529],{"type":24,"tag":55,"props":530,"children":533},{"alt":531,"src":532},"賭場2","https://cdn.lucas-chen.website/2023/11/23/16.jpg",[],{"type":24,"tag":39,"props":535,"children":536},{},[],{"type":24,"tag":43,"props":538,"children":539},{},[540],{"type":24,"tag":55,"props":541,"children":544},{"alt":542,"src":543},"賭場3","https://cdn.lucas-chen.website/2023/11/23/21.jpg",[],{"type":24,"tag":39,"props":546,"children":547},{},[],{"type":24,"tag":43,"props":549,"children":550},