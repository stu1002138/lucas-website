,"tag":39,"props":750,"children":751},{},[],{"type":24,"tag":25,"props":753,"children":755},{"id":754},"心得",[756],{"type":24,"tag":30,"props":757,"children":759},{"className":758},[33,34],[760],{"type":37,"value":754},{"type":24,"tag":39,"props":762,"children":763},{},[],{"type":24,"tag":43,"props":765,"children":766},{},[767],{"type":37,"value":768},"澳門快閃 三天兩夜 其實算蠻夠的",{"type":24,"tag":43,"props":770,"children":771},{},[772],{"type":37,"value":773},"除了賭場",{"type":24,"tag":43,"props":775,"children":776},{},[777],{"type":37,"value":778},"其實很快就逛完了",{"type":24,"tag":43,"props":780,"children":781},{},[782],{"type":37,"value":783},"後來查了一下",{"type":24,"tag":43,"props":785,"children":786},{},[787],{"type":37,"value":788},"蠻多喜歡賭博的人",{"type":24,"tag":43,"props":790,"children":791},{},[792],{"type":37,"value":793},"其實可以靠賭博換取住宿",{"type":24,"tag":43,"props":795,"children":796},{},[797],{"type":37,"value":798},"但可能本金要不少ＸＤ",{"type":24,"tag":43,"props":800,"children":801},{},[802],{"type":37,"value":803},"這趟澳門行 算是對於賭場 大開眼界",{"type":24,"tag":43,"props":805,"children":806},{},[807],{"type":37,"value":808},"看到蠻多土豪  籌碼都是好幾萬",{"type":24,"tag":43,"props":810,"children":811},{},[812],{"type":37,"value":813},"相比之下",{"type":24,"tag":43,"props":815,"children":816},{},[817],{"type":37,"value":818},"對於我這樣的小資族，雖然無法豪賭，但這趟旅程依然充滿了新鮮與刺激的體驗。",{"type":24,"tag":43,"props":820,"children":821},{},[822],{"type":37,"value":823},"感謝我朋友有這機會讓我去澳門！",{"type":24,"tag":43,"props":825,"children":826},{},[827],{"type":37,"value":828},"期待下次旅行！",{"title":8,"searchDepth":830,"depth":830,"links":831},2,[832,833,834,835,836],{"id":27,"depth":830,"text":27},{"id":75,"depth":830,"text":75},{"id":261,"depth":830,"text":261},{"id":578,"depth":830,"text":578},{"id":754,"depth":830,"text":754},"markdown","content:travel:2023:11:23:trip-to-macau.md","content","travel/2023/11/23/trip-to-macau.md","travel/2023/11/23/trip-to-macau","md",1774340645084]