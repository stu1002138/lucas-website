[{"data":1,"prerenderedAt":452},["ShallowReactive",2],{"tag-Chu-yu":3},[4],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"date":11,"keywords":12,"body":18,"_type":446,"_id":447,"_source":448,"_file":449,"_stem":450,"_extension":451},"/en/food/2023/06/11/chu-yu-omakase","11",false,"","Chu-yu - Japanese Omakase","Third Visit to Chuyu Sushi - A Japanese Omakase Restaurant in Taiwan.","2023-06-11T00:00:00.000Z",[13,14,15,16,17],"Food","Omakase","Japanese Cuisine","Chu-yu","Birthday Celebration",{"type":19,"children":20,"toc":443},"root",[21,29,34,39,43,46,62,67,72,77,92,97,102,105,117,122,127,130,141,146,151,156,161,164,175,186,197,208,219,230,241,252,263,274,285,296,307,318,329,340,345,350,355,360,363,374,379,382,392,397,402,407,420,425],{"type":22,"tag":23,"props":24,"children":25},"element","p",{},[26],{"type":27,"value":28},"text","This time, to celebrate my girlfriend's birthday,",{"type":22,"tag":23,"props":30,"children":31},{},[32],{"type":27,"value":33},"I specially booked this Japanese Omakase restaurant – Chuyu Sushi.",{"type":22,"tag":23,"props":35,"children":36},{},[37],{"type":27,"value":38},"This restaurant became a favorite of mine after a friend took me here for my birthday once, and I’ve remembered it ever since.",{"type":22,"tag":40,"props":41,"children":42},"br",{},[],{"type":22,"tag":40,"props":44,"children":45},{},[],{"type":22,"tag":23,"props":47,"children":48},{},[49,51],{"type":27,"value":50},"Image source: ",{"type":22,"tag":52,"props":53,"children":59},"a",{"className":54,"href":56,"rel":57},[55],"text-blue","https://www.facebook.com/chuyu.regent/",[58],"nofollow",[60],{"type":27,"value":61},"Chuyu Sushi - Regent Hotel",{"type":22,"tag":23,"props":63,"children":64},{},[65],{"type":27,"value":66},"Initially, the meal set at Chuyu Sushi was priced at TWD 1200 +10%.",{"type":22,"tag":23,"props":68,"children":69},{},[70],{"type":27,"value":71},"However, with inflation, the prices have increased as well.",{"type":22,"tag":23,"props":73,"children":74},{},[75],{"type":27,"value":76},"This restaurant is located in the B1 level of Regent Hotel Taipei, near Zhongshan MRT Station.",{"type":22,"tag":23,"props":78,"children":79},{},[80,82,90],{"type":27,"value":81},"Before dining, reservations must be made in advance through the ",{"type":22,"tag":52,"props":83,"children":87},{"className":84,"href":85,"rel":86},[55],"https://www.chu-yu.com.tw/",[58],[88],{"type":27,"value":89},"Chuyu Sushi official website",{"type":27,"value":91},".",{"type":22,"tag":23,"props":93,"children":94},{},[95],{"type":27,"value":96},"Full payment is required upfront, either via bank transfer or in-store credit card.",{"type":22,"tag":23,"props":98,"children":99},{},[100],{"type":27,"value":101},"Due to limited seating, I recommend booking early to secure your spot!",{"type":22,"tag":40,"props":103,"children":104},{},[],{"type":22,"tag":23,"props":106,"children":107},{},[108,114],{"type":22,"tag":109,"props":110,"children":113},"img",{"alt":111,"src":112},"Seated","/img/posts/2023/06/11/01.jpg",[],{"type":22,"tag":40,"props":115,"children":116},{},[],{"type":22,"tag":23,"props":118,"children":119},{},[120],{"type":27,"value":121},"Once seated, the staff will first serve a cup of hot tea, along with small appetizers and pickles.",{"type":22,"tag":23,"props":123,"children":124},{},[125],{"type":27,"value":126},"Then, the essence of Omakase slowly unfolds, with each dish meticulously crafted and served.",{"type":22,"tag":40,"props":128,"children":129},{},[],{"type":22,"tag":23,"props":131,"children":132},{},[133,138],{"type":22,"tag":109,"props":134,"children":137},{"alt":135,"src":136},"Appetizer","/img/posts/2023/06/11/02.jpg",[],{"type":22,"tag":40,"props":139,"children":140},{},[],{"type":22,"tag":23,"props":142,"children":143},{},[144],{"type":27,"value":145},"The appetizer is refreshing and whets your appetite, preparing you for the culinary experience ahead.",{"type":22,"tag":23,"props":147,"children":148},{},[149],{"type":27,"value":150},"One by one, the dishes are served.",{"type":22,"tag":23,"props":152,"children":153},{},[154],{"type":27,"value":155},"Although I’ve forgotten most of the specific dish names due to the passage of time, I can confidently say that every dish was fresh and delicious, particularly the seafood used by the restaurant.",{"type":22,"tag":23,"props":157,"children":158},{},[159],{"type":27,"value":160},"Below are some of the dishes we enjoyed during the meal:",{"type":22,"tag":40,"props":162,"children":163},{},[],{"type":22,"tag":23,"props":165,"children":166},{},[167,172],{"type":22,"tag":109,"props":168,"children":171},{"alt":169,"src":170},"Second Dish","/img/posts/2023/06/11/03.jpg",[],{"type":22,"tag":40,"props":173,"children":174},{},[],{"type":22,"tag":23,"props":176,"children":177},{},[178,183],{"type":22,"tag":109,"props":179,"children":182},{"alt":180,"src":181},"Third Dish","/img/posts/2023/06/11/04.jpg",[],{"type":22,"tag":40,"props":184,"children":185},{},[],{"type":22,"tag":23,"props":187,"children":188},{},[189,194],{"type":22,"tag":109,"props":190,"children":193},{"alt":191,"src":192},"Fourth Dish","/img/posts/2023/06/11/05.jpg",[],{"type":22,"tag":40,"props":195,"children":196},{},[],{"type":22,"tag":23,"props":198,"children":199},{},[200,205],{"type":22,"tag":109,"props":201,"children":204},{"alt":202,"src":203},"Fifth Dish","/img/posts/2023/06/11/06.jpg",[],{"type":22,"tag":40,"props":206,"children":207},{},[],{"type":22,"tag":23,"props":209,"children":210},{},[211,216],{"type":22,"tag":109,"props":212,"children":215},{"alt":213,"src":214},"Sixth Dish","/img/posts/2023/06/11/07.jpg",[],{"type":22,"tag":40,"props":217,"children":218},{},[],{"type":22,"tag":23,"props":220,"children":221},{},[222,227],{"type":22,"tag":109,"props":223,"children":226},{"alt":224,"src":225},"Seventh Dish","/img/posts/2023/06/11/08.jpg",[],{"type":22,"tag":40,"props":228,"children":229},{},[],{"type":22,"tag":23,"props":231,"children":232},{},[233,238],{"type":22,"tag":109,"props":234,"children":237},{"alt":235,"src":236},"Eighth Dish","/img/posts/2023/06/11/09.jpg",[],{"type":22,"tag":40,"props":239,"children":240},{},[],{"type":22,"tag":23,"props":242,"children":243},{},[244,249],{"type":22,"tag":109,"props":245,"children":248},{"alt":246,"src":247},"Ninth Dish","/img/posts/2023/06/11/10.jpg",[],{"type":22,"tag":40,"props":250,"children":251},{},[],{"type":22,"tag":23,"props":253,"children":254},{},[255,260],{"type":22,"tag":109,"props":256,"children":259},{"alt":257,"src":258},"Tenth Dish","/img/posts/2023/06/11/11.jpg",[],{"type":22,"tag":40,"props":261,"children":262},{},[],{"type":22,"tag":23,"props":264,"children":265},{},[266,271],{"type":22,"tag":109,"props":267,"children":270},{"alt":268,"src":269},"Eleventh Dish","/img/posts/2023/06/11/12.jpg",[],{"type":22,"tag":40,"props":272,"children":273},{},[],{"type":22,"tag":23,"props":275,"children":276},{},[277,282],{"type":22,"tag":109,"props":278,"children":281},{"alt":279,"src":280},"Twelfth Dish","/img/posts/2023/06/11/13.jpg",[],{"type":22,"tag":40,"props":283,"children":284},{},[],{"type":22,"tag":23,"props":286,"children":287},{},[288,293],{"type":22,"tag":109,"props":289,"children":292},{"alt":290,"src":291},"Thirteenth Dish","/img/posts/2023/06/11/14.jpg",[],{"type":22,"tag":40,"props":294,"children":295},{},[],{"type":22,"tag":23,"props":297,"children":298},{},[299,304],{"type":22,"tag":109,"props":300,"children":303},{"alt":301,"src":302},"Fourteenth Dish","/img/posts/2023/06/11/15.jpg",[],{"type":22,"tag":40,"props":305,"children":306},{},[],{"type":22,"tag":23,"props":308,"children":309},{},[310,315],{"type":22,"tag":109,"props":311,"children":314},{"alt":312,"src":313},"Fifteenth Dish","/img/posts/2023/06/11/16.jpg",[],{"type":22,"tag":40,"props":316,"children":317},{},[],{"type":22,"tag":23,"props":319,"children":320},{},[321,326],{"type":22,"tag":109,"props":322,"children":325},{"alt":323,"src":324},"Sixteenth Dish","/img/posts/2023/06/11/17.jpg",[],{"type":22,"tag":40,"props":327,"children":328},{},[],{"type":22,"tag":23,"props":330,"children":331},{},[332,337],{"type":22,"tag":109,"props":333,"children":336},{"alt":334,"src":335},"Seventeenth Dish","/img/posts/2023/06/11/18.jpg",[],{"type":22,"tag":40,"props":338,"children":339},{},[],{"type":22,"tag":23,"props":341,"children":342},{},[343],{"type":27,"value":344},"The freshness of the ingredients is guaranteed, and each dish is incredibly flavorful.",{"type":22,"tag":23,"props":346,"children":347},{},[348],{"type":27,"value":349},"Midway through, the staff asked if we wanted to add extra lobster or wagyu beef, but since we estimated our portions just right, we declined additional orders.",{"type":22,"tag":23,"props":351,"children":352},{},[353],{"type":27,"value":354},"For the final main course, the restaurant prepares a seafood rice dish.",{"type":22,"tag":23,"props":356,"children":357},{},[358],{"type":27,"value":359},"If you’re still hungry, you can ask for more rice – the service is very considerate.",{"type":22,"tag":40,"props":361,"children":362},{},[],{"type":22,"tag":23,"props":364,"children":365},{},[366,371],{"type":22,"tag":109,"props":367,"children":370},{"alt":368,"src":369},"Eighteenth Dish","/img/posts/2023/06/11/19.jpg",[],{"type":22,"tag":40,"props":372,"children":373},{},[],{"type":22,"tag":23,"props":375,"children":376},{},[377],{"type":27,"value":378},"At the end of the meal, dessert is served, paired with matcha, perfectly concluding the dining experience.",{"type":22,"tag":40,"props":380,"children":381},{},[],{"type":22,"tag":23,"props":383,"children":384},{},[385,389],{"type":22,"tag":109,"props":386,"children":388},{"alt":368,"src":387},"/img/posts/2023/06/11/20.jpg",[],{"type":22,"tag":40,"props":390,"children":391},{},[],{"type":22,"tag":23,"props":393,"children":394},{},[395],{"type":27,"value":396},"The dessert is not overly sweet, and with the matcha, it tastes perfect.",{"type":22,"tag":23,"props":398,"children":399},{},[400],{"type":27,"value":401},"Overall, the food is exquisite, the ingredients are fresh, and the service is thoughtful. I highly recommend everyone to come and try it.",{"type":22,"tag":23,"props":403,"children":404},{},[405],{"type":27,"value":406},"Restaurant Name: Chuyu Sushi - Regent Hotel Taipei",{"type":22,"tag":23,"props":408,"children":409},{},[410,412],{"type":27,"value":411},"Address: ",{"type":22,"tag":52,"props":413,"children":417},{"className":414,"href":415,"rel":416},[55],"https://g.co/kgs/qMtEQUG",[58],[418],{"type":27,"value":419},"B2, No. 3, Lane 39, Section 2, Zhongshan North Road, Zhongshan District, Taipei City",{"type":22,"tag":23,"props":421,"children":422},{},[423],{"type":27,"value":424},"Reservation Hotline: (886)2-23660792 (10:00~21:00)",{"type":22,"tag":23,"props":426,"children":427},{},[428,430,437,440],{"type":27,"value":429},"Official Website: ",{"type":22,"tag":52,"props":431,"children":434},{"className":432,"href":85,"rel":433},[55],[58],[435],{"type":27,"value":436},"Link",{"type":22,"tag":40,"props":438,"children":439},{},[],{"type":22,"tag":40,"props":441,"children":442},{},[],{"title":8,"searchDepth":444,"depth":444,"links":445},2,[],"markdown","content:en:food:2023:06:11:chu-yu-omakase.md","content","en/food/2023/06/11/chu-yu-omakase.md","en/food/2023/06/11/chu-yu-omakase","md",1774343162254]