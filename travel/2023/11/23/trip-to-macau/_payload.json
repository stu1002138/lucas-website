450,"children":451},{},[],{"type":23,"tag":42,"props":453,"children":454},{},[455],{"type":36,"value":456},"所以我玩幾個設施後就因為看不太到",{"type":23,"tag":42,"props":458,"children":459},{},[460],{"type":36,"value":461},"有點暈",{"type":23,"tag":42,"props":463,"children":464},{},[465],{"type":36,"value":466},"蠻可惜的",{"type":23,"tag":42,"props":468,"children":469},{},[470],{"type":36,"value":471},"水上樂園結束後",{"type":23,"tag":42,"props":473,"children":474},{},[475],{"type":36,"value":476},"就去吃晚餐",{"type":23,"tag":42,"props":478,"children":479},{},[480],{"type":36,"value":481},"晚餐吃了港式飲茶",{"type":23,"tag":42,"props":483,"children":484},{},[485],{"type":36,"value":486},"中規中矩",{"type":23,"tag":42,"props":488,"children":489},{},[490],{"type":36,"value":491},"但吃了兩千元....",{"type":23,"tag":38,"props":493,"children":494},{},[],{"type":23,"tag":42,"props":496,"children":497},{},[498],{"type":23,"tag":54,"props":499,"children":502},{"alt":500,"src":501},"港式飲茶","https://cdn.lucas-chen.website/2023/11/23/22.jpg",[],{"type":23,"tag":38,"props":504,"children":505},{},[],{"type":23,"tag":42,"props":507,"children":508},{},[509],{"type":36,"value":510},"晚餐後，我們決定去各大賭場踩點，每個賭場的裝潢都金碧輝煌，真不愧是賭城！雖然沒有大手筆下注，但這些華麗的場景讓人印象深刻。",{"type":23,"tag":38,"props":512,"children":513},{},[],{"type":23,"tag":42,"props":515,"children":516},{},[517],{"type":23,"tag":54,"props":518,"children":521},{"alt":519,"src":520},"賭場1","https://cdn.lucas-chen.website/2023/11/23/15.jpg",[],{"type":23,"tag":38,"props":523,"children":524},{},[],{"type":23,"tag":42,"props":526,"children":527},{},[528],{"type":23,"tag":54,"props":529,"children":532},{"alt":530,"src":531},"賭場2","https://cdn.lucas-chen.website/2023/11/23/16.jpg",[],{"type":23,"tag":38,"props":534,"children":535},{},[],{"type":23,"tag":42,"props":537,"children":538},{},[539],{"type":23,"tag":54,"props":540,"children":543},{"alt":541,"src":542},"賭場3","https://cdn.lucas-chen.website/2023/11/23/21.jpg",[],{"type":23,"tag":38,"props":545,"children":546},{},[],{"type":23,"tag":42,"props"