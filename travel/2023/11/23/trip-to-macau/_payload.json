":68},{"alt":56,"src":67},"https://cdn.lucas-chen.website/2023/11/23/02.jpg",[],{"type":23,"tag":38,"props":70,"children":71},{},[],{"type":23,"tag":24,"props":73,"children":75},{"id":74},"抵達澳門",[76],{"type":23,"tag":29,"props":77,"children":79},{"className":78},[32,33],[80],{"type":36,"value":74},{"type":23,"tag":38,"props":82,"children":83},{},[],{"type":23,"tag":42,"props":85,"children":86},{},[87],{"type":36,"value":88},"抵達澳門後，發現機場附近有許多酒店的接駁車，完全不需要 Taxi 就能輕鬆抵達酒店。我們入住的是新濠影匯。",{"type":23,"tag":38,"props":90,"children":91},{},[],{"type":23,"tag":42,"props":93,"children":94},{},[95],{"type":23,"tag":54,"props":96,"children":99},{"alt":97,"src":98},"搭酒店接駁車","https://cdn.lucas-chen.website/2023/11/23/03.jpg",[],{"type":23,"tag":38,"props":101,"children":102},{},[],{"type":23,"tag":42,"props":104,"children":105},{},[106],{"type":36,"value":107},"酒店外觀 （車上拍的，有點糊）",{"type":23,"tag":38,"props":109,"children":110},{},[],{"type":23,"tag":42,"props":112,"children":113},{},[114],{"type":23,"tag":54,"props":115,"children":118},{"alt":116,"src":117},"酒店外觀","https://cdn.lucas-chen.website/2023/11/23/04.jpg",[],{"type":23,"tag":38,"props":120,"children":121},{},[],{"type":23,"tag":42,"props":123,"children":124},{},[125],{"type":36,"value":126},"入住後，雖然房間不算奢華，但非常舒適，還能看到對面的巴黎鐵塔，彷彿置身於巴黎，令人感到驚喜。",{"type":23,"tag":38,"props":128,"children":129},{},[],{"type":23,"tag":42,"props":131,"children":132},{},[133],{"type":23,"tag":54,"props":134,"children":137},{"alt":135,"src":136},"房間照片","https://cdn.lucas-chen.website/2023/11/23/05.jpg",[],{"type":23,"tag":38,"props":139,"children":140},{},[],{"type":23,"tag":42,"props":142,"children":143},{},[144],{"type":23,"tag":54,"props":145,"children":147},{"alt":135,"src":146},"https://cdn.lucas-chen.website/2023/11/23/06.jpg",[],{"type":23,"tag":38,"props":149,"children":150},{},[],{"type":23,"tag":42,"props":152,"children":153},{},[154],{"type":36,"value":155},"Check-in完畢後",{"type":23,"tag":42,"props":157,"children":158},{},[159],{"type":36,"value":160},"就要去補充體力 吃點東西拉",{"type":23,"tag":42,"props":162,"children":163},{},[164],{"type":36,"value":165},"我們是出去酒店外面 搭外面的 Taxi",{"type":23,"tag":42,"props":167,"children":168},{},[169],{"type":36,"value":170},"到比較多吃的酒店覓食",{"type":23,"tag":42,"props":172,"children":173},{},[174],{"type":36,"value":175},"因為我們到澳門已經很晚了",{"type":23,"tag":42,"props":177,"children":178},{},[179],{"type":36,"value":180},"新濠影匯的餐廳都已經關了",{"type":23,"tag":42,"props":182,"children":183},{},[184],{"type":36,"value":185},"所以我們查到澳門銀河酒店",{"type":23,"tag":42,"props":187,"children":188},{},[189],{"type":36,"value":190},"裡面餐廳還有營業",{"type":23,"tag":42,"props":192,"children":193},{},[194],{"type":36,"value":195},"所以就去裡面找評價不錯的餐廳吃晚餐了",{"type":23,"tag":42,"props":197,"children":198},{},[199],{"type":36,"value":200},"最後選到一間 翠華茶餐廳",{"type":23,"tag":42,"props":202,"children":203},{},[204],{"type":36,"value":205},"旁邊就賭場",{"type":23,"tag":42,"props":207,"children":208},{},[209],{"type":36,"value":210},"很多賭客賭完後來餐廳覓食",{"type":23,"tag":42,"props":212,"children":213},{},[214],{"type":36,"value":215},"看完菜單",{"type":23,"tag":42,"props":217,"children":218},{},[219],{"type":36,"value":220},"澳門消費真不是普通的高",{"type":23,"tag":42,"props":222,"children":223},{},[224],{"type":36,"value":225},"跟台灣物價來比，真的高不少",{"type":23,"tag":42,"props":227,"children":228},{},[229],{"type":36,"value":230},"兩個人只點了兩個魚蛋麵 兩杯奶茶  花了165 澳門幣 (約650台幣)",{"type":23,"tag":38,"props":232,"children":233},{},[],{"type":23,"tag":42,"props":235,"children":236},{},[237],{"type":23,"tag":54,"props":238,"children":241},{"alt":239,"src":240},"第一天晚餐","https://cdn.lucas-chen.website/2023/11/23/07.jpg",[],{"type":23,"tag":38,"props":243,"children":244},{},[],{"type":23,"tag":42,"props":246,"children":247},{},[248],{"type":36,"value":249},"晚餐後，我們隨意逛了逛賭場。賭桌的最低下注額為 300-500 港幣，對於小資族來說壓力頗大，所以我們決定試試老虎機。一百港幣很快輸光，但賭場內有免費飲料供應，至少這點還不錯（笑）。",{"type":23,"tag":42,"props":251,"children":252},{},[253],{"type":36,"value":254},"結束後就回酒店梳洗睡覺了",{"type":23,"tag":38,"props":256,"children":257},{},[],{"type":23,"tag":24,"props":259,"children":261},{"id":260},"第二天",[262],{"type":23,"tag":29,"props":263,"children":265},{"className":264},[32,33],[266],{"type":36,"value":260},{"type":23,"tag":38,"props":268,"children":269},{},[],{"type":23,"tag":42,"props":271,"children":272},{},[273],{"type":36,"value":274},"第二天我們主要行程是在新濠酒店裡面水上樂園玩",{"type":23,"tag":42,"props":276,"children":277},{},[278],{"type":36,"value":279},"所以我們就沒有跑太遠",{"type":23,"tag":42,"props":281,"children":282},{},[283],{"type":36,"value":284},"就先去 氹仔市中心 晃晃 吃午餐",{"type":23,"tag":38,"props":286,"children":287},{},[],{"type":23,"tag":42,"props":289,"children":290},{},[291],{"type":23,"tag":54,"props":292,"children":295},{"alt":293,"src":294},"搭車","https://cdn.lucas-chen.website/2023/11/23/1294217.jpg",[],{"type":23,"tag":38,"props":297,"children":298},{},[],{"type":23,"tag":42,"props":300,"children":301},{},[302],{"type":36,"value":303},"到市中心後看到這個咖哩牛雜",{"type":23,"tag":42,"props":305,"children":306},{},[307],{"type":36,"value":308},"評價不錯，我們就先點一碗來吃",{"type":23,"tag":42,"props":310,"children":311},{},[312],{"type":36,"value":313},"價格 不便宜啊！",{"type":23,"tag":38,"props":315,"children":316},{},[],{"type":23,"tag":42,"props":318,"children":319},{},[320],{"type":23,"tag":54,"props":321,"children":324},{"alt":322,"src":323},"吃咖哩牛雜","https://cdn.lucas-chen.website/2023/11/23/09.jpg",[],{"type":23,"tag":38,"props":326,"children":327},{},[],{"type":23,"tag":42,"props":329,"children":330},{},[331],{"type":36,"value":332},"吃完牛雜",{"type":23,"tag":42,"props":334,"children":335},{},[336],{"type":36,"value":337},"又去吃當地最有名的水蟹粥",{"type":23,"tag":42,"props":339,"children":340},{},[341],{"type":36,"value":342},"我覺得水蟹粥雖然美味，卻沒有特別驚艷。",{"type":23,"tag":38,"props":344,"children":345},{},[],{"type":23,"tag":42,"props":347,"children":348},{},[349],{"type":23,"tag":54,"props":350,"children":353},{"alt":351,"src":352},"水蟹粥菜餚1","https://cdn.lucas-chen.website/2023/11/23/11.jpg",[],{"type":23,"tag":38,"props":355,"children":356},{},[],